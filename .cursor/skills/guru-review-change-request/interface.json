          },
          "example": {
            "id": "standalone_request_input",
            "path": "examples/public-standalone-request-input.json"
          },
          "discriminator": {
            "field": "profile",
            "value": "standalone_request"
          }
        }
      ]
    },
    "invocation": {
      "command_id": "run-skill-command",
      "wrapper": "scripts/invoke.sh",
      "input_binding": {
        "kind": "structured_json",
        "profile_id": "current_issue"
      },
      "stdout_contract": "single_typed_exit",
      "error_schema": {
        "schema_id": "guru-stage0-review-change-request-invocation-error-1.0",
        "path": "schemas/public-invocation-error.schema.json"
      },
      "error_example": {
        "id": "invalid_public_input",
        "path": "examples/public-invocation-error.json"
      },
      "example_argv": [
        "--input",
        "examples/public-current-issue-input.json",
        "--owner-result",
        ".trellis/guru-team/skills/packages/guru-review-change-request/examples/issue-review.json",
        "--owner-prerequisites",
        ".trellis/guru-team/skills/packages/guru-review-change-request/examples/prerequisite-payloads.json",
        "--owner-change-request",
        ".trellis/guru-team/skills/packages/guru-review-change-request/examples/change-request.json"
      ]
    },
