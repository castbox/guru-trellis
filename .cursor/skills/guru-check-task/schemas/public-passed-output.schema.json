{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-production-check-task-output-passed-1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exit_id",
    "task_ref",
    "checked_head",
    "check_ref"
  ],
  "properties": {
    "exit_id": {
      "const": "passed"
    },
    "task_ref": {
      "type": "string",
      "pattern": "^\\.trellis/tasks/[A-Za-z0-9._/-]+$"
    },
    "checked_head": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "check_ref": {
      "type": "string",
      "minLength": 1
    }
  }
}
