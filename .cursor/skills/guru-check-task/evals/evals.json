{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-team-skill-evals-1.0",
  "schema_version": "1.0",
  "skill_name": "guru-check-task",
  "evals": [
    {
      "id": "passed-initial",
      "prompt": "Complete the initial_check semantic owner round and invoke guru-check-task through its public wrapper; return the checker-derived passed route.",
      "expected_exit": "passed",
      "expected_output": "The public DTO is the declared passed route.",
      "input_profile_id": "initial_check",
      "assertions": {
        "deterministic": [
          {
            "id": "expected-route",
            "kind": "json_path",
            "pointer": "/exit_id",
            "operation": "equals",
            "expected": "passed"
          },
          {
            "id": "public-only",
            "kind": "trace",
            "invariant": "public_invocation_only"
          },
          {
            "id": "evals-not-loaded",
            "kind": "trace",
            "invariant": "evals_not_loaded_by_skill"
          },
          {
            "id": "private-runtime-not-read",
            "kind": "trace",
            "invariant": "private_runtime_not_read_by_agent"
          }
        ]
      },
      "files": ["evals/files/passed-initial-input.json", "evals/files/passed-initial-facts.json"]
    },
    {
