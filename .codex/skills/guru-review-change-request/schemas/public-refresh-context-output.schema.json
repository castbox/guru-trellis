{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-stage0-review-change-request-output-refresh-context-1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exit_id",
    "handoff_mode",
    "handoff_repo_root",
    "handoff_route"
  ],
  "properties": {
    "exit_id": {
      "const": "refresh_context"
    },
    "handoff_mode": {
      "enum": [
        "workflow",
        "standalone"
      ]
    },
    "handoff_repo_root": {
      "type": "string",
      "minLength": 1
    },
    "handoff_route": {
      "enum": [
        "repo_change",
        "original_request"
      ]
    }
  }
}
