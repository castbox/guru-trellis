        "standalone"
      ]
    },
    "handoff_target_locator": {
      "type": "string",
      "minLength": 1
    },
    "handoff_repo_locator": {
      "type": "string",
      "minLength": 1
    },
    "handoff_base_branch": {
      "type": "string",
      "minLength": 1
    },
    "handoff_confirmed_action_id": {
      "type": "string",
      "minLength": 1
    },
    "handoff_continuation_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
