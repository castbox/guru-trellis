{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/castbox/guru-trellis/schemas/guru-phase2-check-2.0.json",
  "title": "Guru Phase 2 Check 2.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "skill_id", "generated_at", "mode", "task", "planning", "requirement_provenance", "docs_ssot_plan", "implementation_handoff", "agent_assignment", "repository_snapshot", "check_execution", "scope_qualification", "semantic_review", "human_confirmation", "typed_exit", "route", "reason", "consumer", "facts_sha256"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "skill_id": {"const": "guru-check-task"},
    "generated_at": {"type": "string", "format": "date-time"},
    "mode": {"enum": ["workflow", "standalone"]},
    "task": {"$ref": "#/$defs/task"},
    "planning": {"$ref": "#/$defs/planning"},
    "requirement_provenance": {"$ref": "#/$defs/evidence"},
    "docs_ssot_plan": {"$ref": "#/$defs/docs"},
    "implementation_handoff": {"$ref": "#/$defs/evidence"},
    "agent_assignment": {"$ref": "#/$defs/agent"},
    "repository_snapshot": {"$ref": "#/$defs/repository"},
    "check_execution": {"$ref": "#/$defs/execution"},
    "scope_qualification": {"$ref": "#/$defs/scope"},
    "semantic_review": {"$ref": "#/$defs/review"},
    "human_confirmation": {"$ref": "#/$defs/confirmation"},
    "typed_exit": {"enum": ["passed", "implementation_required", "planning_stale", "blocked"]},
    "route": {"enum": [null, "reapprove_plan", "clarify_requirements"]},
    "reason": {"type": "string", "minLength": 1},
    "consumer": {"$ref": "#/$defs/consumer"},
    "facts_sha256": {"$ref": "#/$defs/sha256"}
  },
  "allOf": [
    {
      "if": {"properties": {"typed_exit": {"const": "passed"}}, "required": ["typed_exit"]},
      "then": {"properties": {"route": {"const": null}, "consumer": {"const": {"kind": "skill", "id": "guru-create-task-commit"}}, "check_execution": {"properties": {"unverified_items": {"not": {"contains": {"properties": {"blocking": {"const": true}}, "required": ["blocking"]}}}}}, "semantic_review": {"properties": {"findings": {"not": {"contains": {"properties": {"status": {"const": "open"}}, "required": ["status"]}}}, "adequacy_dimensions": {"items": {"properties": {"status": {"const": "passed"}}, "required": ["status"]}}, "ai_review_gate": {"properties": {"status": {"const": "passed"}, "full_rerun": {"const": true}}, "required": ["status", "full_rerun"]}}}}}
    },
    {
      "if": {"properties": {"typed_exit": {"const": "implementation_required"}}, "required": ["typed_exit"]},
      "then": {"properties": {"route": {"const": null}, "consumer": {"const": {"kind": "workflow", "id": "guru-resume-implementation"}}, "semantic_review": {"properties": {"findings": {"contains": {"properties": {"status": {"const": "open"}}, "required": ["status"]}}, "ai_review_gate": {"properties": {"status": {"const": "implementation_required"}}, "required": ["status"]}}}}}
    },
    {
      "if": {"properties": {"typed_exit": {"const": "planning_stale"}}, "required": ["typed_exit"]},
      "then": {"properties": {"route": {"enum": ["reapprove_plan", "clarify_requirements"]}, "consumer": {"const": {"kind": "workflow", "id": "guru-task-check-planning-router"}}, "scope_qualification": {"properties": {"candidates": {"contains": {"properties": {"disposition": {"const": "scope_change_required"}}, "required": ["disposition"]}}}}, "semantic_review": {"properties": {"ai_review_gate": {"properties": {"status": {"const": "planning_stale"}}, "required": ["status"]}}}}}
    },
    {
      "if": {"properties": {"typed_exit": {"const": "blocked"}}, "required": ["typed_exit"]},
      "then": {"properties": {"route": {"const": null}, "consumer": {"const": {"kind": "stop", "id": "task-check-blocked"}}, "check_execution": {"properties": {"unverified_items": {"contains": {"properties": {"blocking": {"const": true}}, "required": ["blocking"]}}}}, "semantic_review": {"properties": {"ai_review_gate": {"properties": {"status": {"const": "blocked"}}, "required": ["status"]}}}}}
    },
    {
      "if": {"properties": {"scope_qualification": {"properties": {"candidates": {"contains": {"properties": {"disposition": {"const": "current_scope"}}, "required": ["disposition"]}}}, "required": ["candidates"]}}, "required": ["scope_qualification"]},
      "then": {"properties": {"semantic_review": {"properties": {"findings": {"minItems": 1}}, "required": ["findings"]}}}
    },
    {
      "if": {"properties": {"semantic_review": {"properties": {"findings": {"contains": {"properties": {"status": {"const": "open"}}, "required": ["status"]}}}, "required": ["findings"]}}, "required": ["semantic_review"]},
      "then": {"properties": {"typed_exit": {"const": "implementation_required"}}}
    },
    {
      "if": {"properties": {"scope_qualification": {"properties": {"candidates": {"contains": {"properties": {"disposition": {"const": "scope_change_required"}}, "required": ["disposition"]}}}, "required": ["candidates"]}}, "required": ["scope_qualification"]},
      "then": {"properties": {"typed_exit": {"const": "planning_stale"}}}
    },
    {
      "if": {"properties": {"check_execution": {"properties": {"unverified_items": {"contains": {"properties": {"blocking": {"const": true}}, "required": ["blocking"]}}}, "required": ["unverified_items"]}}, "required": ["check_execution"]},
      "then": {"properties": {"typed_exit": {"const": "blocked"}}}
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "pathDigest": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 0}}},
    "evidence": {"type": "object", "additionalProperties": false, "required": ["summary", "artifacts", "facts_sha256"], "properties": {"summary": {"type": "string", "minLength": 1}, "artifacts": {"type": "array", "items": {"$ref": "#/$defs/pathDigest"}, "uniqueItems": true}, "facts_sha256": {"$ref": "#/$defs/sha256"}}},
    "task": {"type": "object", "additionalProperties": false, "required": ["task_dir", "task_id", "branch", "base_branch", "issue_numbers", "task_identity_sha256"], "properties": {"task_dir": {"type": "string", "pattern": "^\\.trellis/tasks/"}, "task_id": {"type": "string", "minLength": 1}, "branch": {"type": "string", "minLength": 1}, "base_branch": {"type": "string", "minLength": 1}, "issue_numbers": {"type": "array", "items": {"type": "integer", "minimum": 1}, "uniqueItems": true}, "task_identity_sha256": {"$ref": "#/$defs/sha256"}}},
    "planning": {"type": "object", "additionalProperties": false, "required": ["schema_id", "typed_exit", "artifact", "reviewed_artifacts", "facts_sha256"], "properties": {"schema_id": {"const": "guru-planning-approval-2.0"}, "typed_exit": {"const": "approved"}, "artifact": {"$ref": "#/$defs/pathDigest"}, "reviewed_artifacts": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/pathDigest"}}, "facts_sha256": {"$ref": "#/$defs/sha256"}}},
    "docs": {"type": "object", "additionalProperties": false, "required": ["strategy", "durable_paths", "sync_result", "task_delta_merged", "task_history_only", "no_update_reason", "followup_or_pr_limit", "facts_sha256"], "properties": {"strategy": {"enum": ["ssot_first", "delta_first", "bootstrap_or_repair_docs", "no_docs_update_needed"]}, "durable_paths": {"type": "array", "items": {"$ref": "#/$defs/pathDigest"}, "uniqueItems": true}, "sync_result": {"type": "string", "minLength": 1}, "task_delta_merged": {"type": "boolean"}, "task_history_only": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "no_update_reason": {"type": ["string", "null"]}, "followup_or_pr_limit": {"type": ["string", "null"]}, "facts_sha256": {"$ref": "#/$defs/sha256"}}},
    "agent": {"type": "object", "additionalProperties": false, "required": ["artifact_path", "implementation_agent_ids", "check_agent_ids", "recovery_complete", "phase2_state_sha256", "facts_sha256"], "properties": {"artifact_path": {"type": "string", "pattern": "^\\.trellis/tasks/(?:archive/[^/]+/)?[^/]+/agent-assignment\\.json$"}, "implementation_agent_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "check_agent_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "recovery_complete": {"const": true}, "phase2_state_sha256": {"$ref": "#/$defs/sha256"}, "facts_sha256": {"$ref": "#/$defs/sha256"}}},
    "repository": {"type": "object", "additionalProperties": false, "required": ["base_ref", "base_head", "head", "diff_range", "dirty_paths", "reviewed_paths", "snapshot_sha256"], "properties": {"base_ref": {"type": "string", "minLength": 1}, "base_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "head": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "diff_range": {"type": "string", "minLength": 1}, "dirty_paths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "reviewed_paths": {"type": "array", "items": {"$ref": "#/$defs/pathDigest"}, "uniqueItems": true}, "snapshot_sha256": {"$ref": "#/$defs/sha256"}}},
    "command": {"type": "object", "additionalProperties": false, "required": ["id", "argv", "exit_code", "stdout_sha256", "stdout_size_bytes", "stderr_sha256", "stderr_size_bytes", "summary"], "properties": {"id": {"type": "string", "minLength": 1}, "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "exit_code": {"type": "integer"}, "stdout_sha256": {"$ref": "#/$defs/sha256"}, "stdout_size_bytes": {"type": "integer", "minimum": 0}, "stderr_sha256": {"$ref": "#/$defs/sha256"}, "stderr_size_bytes": {"type": "integer", "minimum": 0}, "summary": {"type": "string", "minLength": 1}}},
    "worker": {"type": "object", "additionalProperties": false, "required": ["source", "agent_id", "summary", "evidence_only", "facts_sha256"], "properties": {"source": {"enum": ["official_trellis_check", "declared_platform_alternative"]}, "agent_id": {"type": "string", "minLength": 1}, "summary": {"type": "string", "minLength": 1}, "evidence_only": {"const": true}, "facts_sha256": {"$ref": "#/$defs/sha256"}}},
    "unverified": {"type": "object", "additionalProperties": false, "required": ["id", "command_or_area", "reason", "impact", "blocking"], "properties": {"id": {"type": "string", "minLength": 1}, "command_or_area": {"type": "string", "minLength": 1}, "reason": {"type": "string", "minLength": 1}, "impact": {"type": "string", "minLength": 1}, "blocking": {"type": "boolean"}}},
    "execution": {"type": "object", "additionalProperties": false, "required": ["commands", "worker_evidence", "unverified_items", "execution_sha256"], "properties": {"commands": {"type": "array", "items": {"$ref": "#/$defs/command"}}, "worker_evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/worker"}}, "unverified_items": {"type": "array", "items": {"$ref": "#/$defs/unverified"}, "uniqueItems": true}, "execution_sha256": {"$ref": "#/$defs/sha256"}}},
    "candidate": {"type": "object", "additionalProperties": false, "required": ["id", "summary", "trigger_refs", "normal_path_reproduction", "disposition", "route_basis", "severity", "finding_id"], "properties": {"id": {"type": "string", "minLength": 1}, "summary": {"type": "string", "minLength": 1}, "trigger_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "normal_path_reproduction": {"type": "string", "minLength": 1}, "disposition": {"enum": ["current_scope", "scope_change_required", "followup_proposal", "out_of_scope"]}, "route_basis": {"type": "string", "minLength": 1}, "severity": {"enum": [null, "P0", "P1", "P2", "P3"]}, "finding_id": {"type": ["string", "null"]}}, "allOf": [{"if": {"properties": {"disposition": {"const": "current_scope"}}, "required": ["disposition"]}, "then": {"properties": {"severity": {"enum": ["P0", "P1", "P2", "P3"]}, "finding_id": {"type": "string", "minLength": 1}}}, "else": {"properties": {"severity": {"const": null}, "finding_id": {"const": null}}}}]},
    "scope": {"type": "object", "additionalProperties": false, "required": ["candidates", "scope_sha256"], "properties": {"candidates": {"type": "array", "items": {"$ref": "#/$defs/candidate"}, "uniqueItems": true}, "scope_sha256": {"$ref": "#/$defs/sha256"}}},
    "finding": {"type": "object", "additionalProperties": false, "required": ["id", "candidate_id", "severity", "summary", "path", "blocking", "status"], "properties": {"id": {"type": "string", "minLength": 1}, "candidate_id": {"type": "string", "minLength": 1}, "severity": {"enum": ["P0", "P1", "P2", "P3"]}, "summary": {"type": "string", "minLength": 1}, "path": {"type": ["string", "null"]}, "blocking": {"const": true}, "status": {"enum": ["open", "resolved"]}}},
    "dimension": {"type": "object", "additionalProperties": false, "required": ["id", "status", "summary", "evidence_refs", "affected_sha256", "finding_ids", "unverified_ids"], "properties": {"id": {"enum": ["requirements", "design", "implementation", "tests", "docs_ssot", "cross_layer", "compatibility", "deployment_and_operations", "agent_recovery", "verification_completeness"]}, "status": {"enum": ["passed", "failed", "blocked"]}, "summary": {"type": "string", "minLength": 1}, "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}}, "affected_sha256": {"$ref": "#/$defs/sha256"}, "finding_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "unverified_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}}},
    "gate": {"type": "object", "additionalProperties": false, "required": ["status", "summary", "planning_facts_sha256", "snapshot_sha256", "scope_sha256", "adequacy_sha256", "findings_count", "full_rerun", "full_round_sha256"], "properties": {"status": {"enum": ["passed", "implementation_required", "planning_stale", "blocked"]}, "summary": {"type": "string", "minLength": 1}, "planning_facts_sha256": {"$ref": "#/$defs/sha256"}, "snapshot_sha256": {"$ref": "#/$defs/sha256"}, "scope_sha256": {"$ref": "#/$defs/sha256"}, "adequacy_sha256": {"$ref": "#/$defs/sha256"}, "findings_count": {"type": "integer", "minimum": 0}, "full_rerun": {"type": "boolean"}, "full_round_sha256": {"$ref": "#/$defs/sha256"}}},
    "review": {"type": "object", "additionalProperties": false, "required": ["adequacy_dimensions", "findings", "adequacy_sha256", "ai_review_gate"], "properties": {"adequacy_dimensions": {"type": "array", "minItems": 10, "maxItems": 10, "items": {"$ref": "#/$defs/dimension"}, "uniqueItems": true}, "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}, "uniqueItems": true}, "adequacy_sha256": {"$ref": "#/$defs/sha256"}, "ai_review_gate": {"$ref": "#/$defs/gate"}}},
    "confirmation": {"type": "object", "additionalProperties": false, "required": ["kind", "status", "summary", "confirmed_at"], "properties": {"kind": {"const": "not-required"}, "status": {"const": "not_required"}, "summary": {"type": "string", "minLength": 1}, "confirmed_at": {"const": null}}},
    "consumer": {"type": "object", "additionalProperties": false, "required": ["kind", "id"], "properties": {"kind": {"enum": ["skill", "workflow", "stop"]}, "id": {"type": "string", "minLength": 1}}}
  }
}
