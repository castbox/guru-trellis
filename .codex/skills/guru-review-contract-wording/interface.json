{
  "$schema": "../../schemas/skill-interface-1.3.schema.json",
  "schema_version": "1.3",
  "id": "guru-review-contract-wording",
  "name": "guru-review-contract-wording",
  "description": "Review controlled contract wording through fixed change-request, planning-artifact, or explicit-path scope, semantic revision and classification, deterministic evidence, and typed exits.",
  "state": "active",
  "judgment_mode": "semantic",
  "modes": {
    "workflow": {
      "routing": "global_workflow",
      "entry_precondition_ids": [
        "runtime_dependency",
        "review_scope",
        "mutation_authority",
        "semantic_evidence",
        "invocation_freshness"
      ]
    },
    "standalone": {
      "routing": "direct_discovery",
      "entry_precondition_ids": [
        "runtime_dependency",
        "review_scope",
        "mutation_authority",
        "semantic_evidence",
        "invocation_freshness"
      ]
    }
  },
  "entry_preconditions": [
    {
      "id": "runtime_dependency",
      "evidence": "installed extension manifest, dispatcher, active package inventory and declared record/check runtime commands",
      "binding": "complete compatible Guru Team preset runtime",
      "freshness": "validated by run-skill-command before every runtime command"
    },
    {
      "id": "review_scope",
      "evidence": "one complete fixed profile scope with normalized item identities and current content hashes",
      "binding": "change_request title/body plus selected authoritative comments, the three planning artifacts, or the explicit repo-relative Markdown paths",
      "freshness": "the checker rebuilds the selected profile scope and rejects selector narrowing or content drift"
    },
    {
      "id": "mutation_authority",
      "evidence": "AI-reviewed authority for each proposed content mutation, exact confirmed-payload digest, and current live mutation-result identity when required",
      "binding": "only the issue, draft, planning artifact, or explicit Markdown content authorized by the invocation",
      "freshness": "live issue revisions bind source/locator/field, preimage, confirmed content, current reread content and source update time through rescan and checking"
    },
    {
      "id": "semantic_evidence",
      "evidence": "AI-authored revisions, retained-hit classifications and reasons, common Review Gate judgment, planning-profile semantic dimensions when applicable, and conditional human confirmation",
      "binding": "the complete current deterministic scan",
      "freshness": "every content change rebuilds scope and scan before semantic evidence can be recorded"
    },
    {
      "id": "invocation_freshness",
      "evidence": "mode, profile, scope, scan, semantic review, confirmation, result identities and caller route",
      "binding": "one current closed-loop review round",
      "freshness": "all identities and the declared profile/exit remain current at typed-exit validation"
    }
  ],
  "runtime_dependency": {
    "extension_id": "guru-team",
    "api_version": "1.0",
    "manifest_path": ".trellis/guru-team/extension.json",
    "dispatcher": "run-skill-command",
    "distribution": "guru-team-preset",
    "package_portability": "not-self-contained"
  },
  "ordered_stages": [
    "forward_behavior",
    "ai_review_gate",
    "conditional_human_confirmation",
    "recorder_validator",
    "typed_exit"
  ],
  "artifacts": [
    {
      "id": "contract_wording_review_example",
      "path": "examples/contract-wording-review.json"
    },
    {
      "id": "public_input_change_request_example",
      "path": "examples/public-change-request-input.json"
    },
    {
      "id": "public_input_planning_artifacts_example",
      "path": "examples/public-planning-artifacts-input.json"
    },
    {
      "id": "public_input_explicit_paths_example",
      "path": "examples/public-explicit-paths-input.json"
    },
    {
      "id": "public_invocation_error_example",
      "path": "examples/public-invocation-error.json"
    },
    {
      "id": "public_output_pass_example",
      "path": "examples/public-pass-output.json"
    },
    {
      "id": "public_output_content_changed_example",
      "path": "examples/public-content-changed-output.json"
    },
    {
      "id": "public_output_blocked_example",
      "path": "examples/public-blocked-output.json"
    }
  ],
  "schemas": [
    {
      "id": "contract_wording_review_schema",
      "path": "schemas/contract-wording-review.schema.json"
    },
    {
      "id": "public_input_change_request",
      "path": "schemas/public-change-request-input.schema.json"
    },
    {
      "id": "public_input_planning_artifacts",
      "path": "schemas/public-planning-artifacts-input.schema.json"
    },
    {
      "id": "public_input_explicit_paths",
      "path": "schemas/public-explicit-paths-input.schema.json"
    },
    {
      "id": "public_input_aggregate",
      "path": "schemas/public-input.schema.json"
    },
    {
      "id": "public_invocation_error",
      "path": "schemas/public-invocation-error.schema.json"
    },
    {
      "id": "public_output_pass",
      "path": "schemas/public-pass-output.schema.json"
    },
    {
      "id": "public_output_content_changed",
      "path": "schemas/public-content-changed-output.schema.json"
    },
    {
      "id": "public_output_blocked",
      "path": "schemas/public-blocked-output.schema.json"
    }
  ],
  "validators": [
    {
      "id": "contract_wording_recorder",
      "command": "scripts/record-contract-wording-review.sh",
      "runtime_command": "record-contract-wording-review",
      "objective_scope": "fixed profile scope reconstruction, deterministic scan, schema and whitelist validation, exact planning-profile dimension shape/value validation, derived unchecked hits, live issue payload/result identities and canonical digests"
    },
    {
      "id": "contract_wording_checker",
      "command": "scripts/check-contract-wording-review.sh",
      "runtime_command": "check-contract-wording-review",
      "objective_scope": "published schema, fixed scope and scan completeness, selected-comment metadata, live issue payload/preimage/result binding, content freshness, classification structure, exact planning-profile dimension shape/value validation, Gate/exit biconditional and result digest validation"
    },
    {
      "id": "public_invocation",
      "command": "scripts/invoke.sh",
      "runtime_command": "invoke-stage0-skill",
      "objective_scope": "Caller-owned input validation and deterministic typed-exit serialization after the owner closed loop"
    }
  ],
  "external_exits": [
    {
      "id": "pass",
      "evidence": "current complete scope and scan, zero unchecked hits, passed AI Review Gate, and no unconsumed content revision",
      "consumer": {
        "kind": "workflow",
        "id": "guru-contract-wording-pass-router"
      }
    },
    {
      "id": "content_changed",
      "evidence": "one or more authorized revisions are bound to rebuilt scope, current content hashes, a complete rescan, and a passed AI Review Gate",
      "consumer": {
        "kind": "workflow",
        "id": "guru-contract-wording-change-router"
      }
    },
    {
      "id": "blocked",
      "evidence": "missing scope or mutation authority, unconfirmed semantic change, refused required mutation, unchecked violation, or blocked AI Review Gate",
      "consumer": {
        "kind": "stop",
        "id": "contract-wording-blocked"
      }
    }
  ],
  "reentry": {
    "identity": "mode, profile, normalized scope items, scope/scan digests, current hits, revisions, classifications, Review Gate, confirmation and result digest",
    "freshness": "every content mutation invalidates prior hits and semantic evidence; stale replacement is explicit, while a current content_changed/blocked result may be superseded only by a different, fully current same-profile result bound to its exact prior facts_sha256; identical results and current pass are protected",
    "stale_behavior": "fail_closed"
  },
  "tests": [
    "tests/test_contract.py"
  ],
  "platform_destinations": [
    "shared",
    "codex",
    "cursor",
    "claude"
  ],
  "public_contracts": {
    "input": {
      "kind": "structured_json",
      "aggregate_schema": {
        "schema_id": "guru-stage0-review-contract-wording-input-aggregate-1.0",
        "path": "schemas/public-input.schema.json"
      },
      "profiles": [
        {
          "id": "change_request",
          "schema": {
            "schema_id": "guru-stage0-review-contract-wording-input-change-request-1.0",
            "path": "schemas/public-change-request-input.schema.json"
          },
          "example": {
            "id": "change_request_input",
            "path": "examples/public-change-request-input.json"
          },
          "discriminator": {
            "field": "profile",
            "value": "change_request"
          }
        },
        {
          "id": "planning_artifacts",
          "schema": {
            "schema_id": "guru-stage0-review-contract-wording-input-planning-artifacts-1.0",
            "path": "schemas/public-planning-artifacts-input.schema.json"
          },
          "example": {
            "id": "planning_artifacts_input",
            "path": "examples/public-planning-artifacts-input.json"
          },
          "discriminator": {
            "field": "profile",
            "value": "planning_artifacts"
          }
        },
        {
          "id": "explicit_paths",
          "schema": {
            "schema_id": "guru-stage0-review-contract-wording-input-explicit-paths-1.0",
            "path": "schemas/public-explicit-paths-input.schema.json"
          },
          "example": {
            "id": "explicit_paths_input",
            "path": "examples/public-explicit-paths-input.json"
          },
          "discriminator": {
            "field": "profile",
            "value": "explicit_paths"
          }
        }
      ]
    },
    "invocation": {
      "command_id": "run-skill-command",
      "wrapper": "scripts/invoke.sh",
      "input_binding": {
        "kind": "structured_json",
        "profile_id": "planning_artifacts"
      },
      "stdout_contract": "single_typed_exit",
      "error_schema": {
        "schema_id": "guru-stage0-review-contract-wording-invocation-error-1.0",
        "path": "schemas/public-invocation-error.schema.json"
      },
      "error_example": {
        "id": "invalid_public_input",
        "path": "examples/public-invocation-error.json"
      },
      "example_argv": [
        "--input",
        "examples/public-planning-artifacts-input.json",
        "--owner-result",
        ".trellis/guru-team/skills/packages/guru-review-contract-wording/examples/contract-wording-review.json"
      ]
    },
    "outputs": [
      {
        "exit_id": "pass",
        "schema": {
          "schema_id": "guru-stage0-review-contract-wording-output-pass-1.0",
          "path": "schemas/public-pass-output.schema.json"
        },
        "example": {
          "id": "pass_output",
          "path": "examples/public-pass-output.json"
        },
        "consumer_use_ids": [
          "project_pass"
        ]
      },
      {
        "exit_id": "content_changed",
        "schema": {
          "schema_id": "guru-stage0-review-contract-wording-output-content-changed-1.0",
          "path": "schemas/public-content-changed-output.schema.json"
        },
        "example": {
          "id": "content_changed_output",
          "path": "examples/public-content-changed-output.json"
        },
        "consumer_use_ids": [
          "project_content_changed"
        ]
      },
      {
        "exit_id": "blocked",
        "schema": {
          "schema_id": "guru-stage0-review-contract-wording-output-blocked-1.0",
          "path": "schemas/public-blocked-output.schema.json"
        },
        "example": {
          "id": "blocked_output",
          "path": "examples/public-blocked-output.json"
        },
        "consumer_use_ids": [
          "project_blocked"
        ]
      }
    ],
    "consumer_inputs": [
      {
        "id": "pass_workflow_input",
        "consumer": {
          "kind": "workflow",
          "id": "guru-contract-wording-pass-router"
        },
        "payload_kind": "structured_json",
        "contract": {
          "kind": "json_schema",
          "schema_id": "guru-stage0-review-contract-wording-workflow-pass-input-1.0",
          "path": "consumers/workflow/stage0/review-contract-wording-pass.schema.json"
        }
      },
      {
        "id": "content_changed_workflow_input",
        "consumer": {
          "kind": "workflow",
          "id": "guru-contract-wording-change-router"
        },
        "payload_kind": "structured_json",
        "contract": {
          "kind": "json_schema",
          "schema_id": "guru-stage0-review-contract-wording-workflow-content_changed-input-1.0",
          "path": "consumers/workflow/stage0/review-contract-wording-content-changed.schema.json"
        }
      },
      {
        "id": "blocked_stop_input",
        "consumer": {
          "kind": "stop",
          "id": "contract-wording-blocked"
        },
        "payload_kind": "zero_payload"
      }
    ],
    "projections": [
      {
        "id": "project_pass",
        "exit_id": "pass",
        "consumer_input_id": "pass_workflow_input",
        "operation": "direct"
      },
      {
        "id": "project_content_changed",
        "exit_id": "content_changed",
        "consumer_input_id": "content_changed_workflow_input",
        "operation": "direct"
      },
      {
        "id": "project_blocked",
        "exit_id": "blocked",
        "consumer_input_id": "blocked_stop_input",
        "operation": "select",
        "mappings": []
      }
    ],
    "private_artifacts": [
      {
        "id": "wording_review",
        "kind": "gate_evidence",
        "schema": {
          "schema_id": "https://github.com/castbox/guru-trellis/schemas/guru-contract-wording-review-1.0.json",
          "path": "schemas/contract-wording-review.schema.json"
        },
        "persistence": "task_local_tracked"
      }
    ]
  }
}
