{
  "$schema": "../../schemas/skill-interface-1.3.schema.json",
  "schema_version": "1.3",
  "id": "guru-check-task",
  "name": "guru-check-task",
  "description": "Check a complete task through scope-first semantic review, full validation evidence, Docs SSOT reconciliation, finding reruns, and four typed exits.",
  "state": "active",
  "judgment_mode": "semantic",
  "modes": {
    "workflow": {
      "routing": "global_workflow",
      "entry_precondition_ids": [
        "runtime_dependency",
        "task_workspace",
        "approved_planning",
        "requirement_provenance",
        "implementation_handoff",
        "repository_check_inputs",
        "docs_ssot_plan",
        "issue_scope_ledger",
        "agent_assignment_recovery",
        "repository_snapshot",
        "invocation_freshness"
      ]
    },
    "standalone": {
      "routing": "direct_discovery",
      "entry_precondition_ids": [
        "runtime_dependency",
        "task_workspace",
        "approved_planning",
        "requirement_provenance",
        "implementation_handoff",
        "repository_check_inputs",
        "docs_ssot_plan",
        "issue_scope_ledger",
        "agent_assignment_recovery",
        "repository_snapshot",
        "invocation_freshness"
      ]
    }
  },
  "entry_preconditions": [
    {
      "id": "runtime_dependency",
      "evidence": "installed extension manifest, dispatcher, active package inventory, schema, and phase2 record/check runtime commands",
      "binding": "complete compatible Guru Team preset runtime",
      "freshness": "run-skill-command validates before every command"
    },
    {
      "id": "task_workspace",
      "evidence": "direct active task locator, task.json, ignored runtime workspace mapping, checkout, and source boundary facts",
      "binding": "one active task in its expected worktree",
      "freshness": "rebuilt before record and check"
    },
    {
      "id": "approved_planning",
      "evidence": "checker-validated current guru-planning-approval-2.0 approved artifact and three planning documents",
      "binding": "exact approved planning inputs",
      "freshness": "planning checker and document digests rerun"
    },
    {
      "id": "requirement_provenance",
      "evidence": "current approved load-bearing provenance and requirement authorities",
      "binding": "task scope and review triggers",
      "freshness": "linked planning projection remains current"
    },
    {
      "id": "implementation_handoff",
      "evidence": "completed implement-agent handoff with files, Docs SSOT execution, tests, risks, and deferred validation",
      "binding": "implementation claimed for this task snapshot",
      "freshness": "reviewed in the current complete round"
    },
    {
      "id": "repository_check_inputs",
      "evidence": "repository-defined lint, type, test, schema, generated, drift, install, and update commands plus explicit non-applicability",
      "binding": "applicable validation plan",
      "freshness": "commands and results belong to the current round"
    },
    {
      "id": "docs_ssot_plan",
      "evidence": "approved strategy, durable paths, task delta, task-history-only content, and merge/no-update/follow-up boundary",
      "binding": "final docs reconciliation",
      "freshness": "locator and affected path digests are current"
    },
    {
      "id": "issue_scope_ledger",
      "evidence": "current primary, close, related, follow-up, and decision categories",
      "binding": "accepted issue scope",
      "freshness": "semantic ledger digest rebuilt"
    },
    {
      "id": "agent_assignment_recovery",
      "evidence": "implementation/check assignment and complete failed, unfinished, stale, replacement, and completed recovery chain",
      "binding": "only completed evidence enters pass",
      "freshness": "assignment checker rerun"
    },
    {
      "id": "repository_snapshot",
      "evidence": "base, HEAD, diff range, complete dirty paths, reviewed paths and digests",
      "binding": "one full-scope check round",
      "freshness": "rebuilt around record and during check"
    },
    {
      "id": "invocation_freshness",
      "evidence": "mode, all entry projections, scope candidates, adequacy, findings, unverified items, Gate, typed exit, route, consumer and facts digest",
      "binding": "one complete guru-check-task invocation",
      "freshness": "checker rejects stale, partial, multiple, or mismatched evidence"
    }
  ],
  "runtime_dependency": {
    "extension_id": "guru-team",
    "api_version": "1.0",
    "manifest_path": ".trellis/guru-team/extension.json",
    "dispatcher": "run-skill-command",
    "distribution": "guru-team-preset",
    "package_portability": "not-self-contained"
  },
  "ordered_stages": [
    "forward_behavior",
    "ai_review_gate",
    "conditional_human_confirmation",
    "recorder_validator",
    "typed_exit"
  ],
  "artifacts": [
    {
      "id": "phase2_check_example",
      "path": "examples/phase2-check.json"
    },
    {
      "id": "public_input_initial_check_example",
      "path": "examples/public-initial-check-input.json"
    },
    {
      "id": "public_input_finding_fix_rerun_example",
      "path": "examples/public-finding-fix-rerun-input.json"
    },
    {
      "id": "public_input_planning_reentry_example",
      "path": "examples/public-planning-reentry-input.json"
    },
    {
      "id": "public_invocation_error_example",
      "path": "examples/public-invocation-error.json"
    },
    {
      "id": "public_output_passed_example",
      "path": "examples/public-passed-output.json"
    },
    {
      "id": "public_output_implementation_required_example",
      "path": "examples/public-implementation-required-output.json"
    },
    {
      "id": "public_output_planning_stale_example",
      "path": "examples/public-planning-stale-output.json"
    },
    {
      "id": "public_output_blocked_example",
      "path": "examples/public-blocked-output.json"
    }
  ],
  "schemas": [
    {
      "id": "phase2_check_schema",
      "path": "schemas/phase2-check.schema.json"
    },
    {
      "id": "public_input_initial_check",
      "path": "schemas/public-initial-check-input.schema.json"
    },
    {
      "id": "public_input_finding_fix_rerun",
      "path": "schemas/public-finding-fix-rerun-input.schema.json"
    },
    {
      "id": "public_input_planning_reentry",
      "path": "schemas/public-planning-reentry-input.schema.json"
    },
    {
      "id": "public_input_aggregate",
      "path": "schemas/public-input.schema.json"
    },
    {
      "id": "public_invocation_error",
      "path": "schemas/public-invocation-error.schema.json"
    },
    {
      "id": "public_output_passed",
      "path": "schemas/public-passed-output.schema.json"
    },
    {
      "id": "public_output_implementation_required",
      "path": "schemas/public-implementation-required-output.schema.json"
    },
    {
      "id": "public_output_planning_stale",
      "path": "schemas/public-planning-stale-output.schema.json"
    },
    {
      "id": "public_output_blocked",
      "path": "schemas/public-blocked-output.schema.json"
    }
  ],
  "validators": [
    {
      "id": "phase2_check_recorder",
      "command": "scripts/record-phase2-check.sh",
      "runtime_command": "record-phase2-check",
      "objective_scope": "AI-authored closed input consumption; task, approved planning, ledger, agent, repository and reviewed-path fact rebuild; schema, reference, digest, full-round and exit/consumer validation; single artifact write"
    },
    {
      "id": "phase2_check_checker",
      "command": "scripts/check-phase2-check.sh",
      "runtime_command": "check-phase2-check",
      "objective_scope": "published v2 schema, current task/planning/ledger/agent/HEAD/diff/dirty/reviewed-path facts, scope/finding references, full-round identity, Gate/exit/route/consumer union, artifact digest and post-commit coverage"
    },
    {
      "id": "public_invocation",
      "command": "scripts/invoke.sh",
      "runtime_command": "invoke-stage0-skill",
      "objective_scope": "Caller-owned production input validation, owner recorder/checker or candidate builder execution, and deterministic single typed-exit serialization"
    }
  ],
  "external_exits": [
    {
      "id": "passed",
      "evidence": "all adequacy dimensions passed, no open current-scope finding or blocking unverified item, complete recovery, and current full rerun",
      "consumer": {
        "kind": "skill",
        "id": "guru-create-task-commit"
      }
    },
    {
      "id": "implementation_required",
      "evidence": "one or more open findings in current approved scope",
      "consumer": {
        "kind": "workflow",
        "id": "guru-resume-implementation"
      }
    },
    {
      "id": "planning_stale",
      "evidence": "planning evidence is stale or a candidate requires requirement, authority, or scope change",
      "consumer": {
        "kind": "workflow",
        "id": "guru-task-check-planning-router"
      }
    },
    {
      "id": "blocked",
      "evidence": "required evidence or an external dependency prevents a reliable complete check",
      "consumer": {
        "kind": "stop",
        "id": "task-check-blocked"
      }
    }
  ],
  "reentry": {
    "identity": "mode, task, approved planning, authorities, Docs SSOT plan, ledger, implementation/worker evidence, command results, repository snapshot, scope/adequacy/findings/unverified digests, full-round identity, Gate, exit, route, consumer and facts digest",
    "freshness": "every implementation fix or planning/authority/ledger/agent/repository drift reruns all eleven entry checks and the complete task scope",
    "stale_behavior": "fail_closed"
  },
  "tests": [
    "tests/test_contract.py"
  ],
  "platform_destinations": [
    "shared",
    "codex",
    "cursor",
    "claude"
  ],
  "public_contracts": {
    "input": {
      "kind": "structured_json",
      "aggregate_schema": {
        "schema_id": "guru-production-check-task-input-aggregate-1.0",
        "path": "schemas/public-input.schema.json"
      },
      "profiles": [
        {
          "id": "initial_check",
          "schema": {
            "schema_id": "guru-production-check-task-input-initial-check-1.0",
            "path": "schemas/public-initial-check-input.schema.json"
          },
          "example": {
            "id": "initial_check_input",
            "path": "examples/public-initial-check-input.json"
          },
          "discriminator": {
            "field": "profile",
            "value": "initial_check"
          }
        },
        {
          "id": "finding_fix_rerun",
          "schema": {
            "schema_id": "guru-production-check-task-input-finding-fix-rerun-1.0",
            "path": "schemas/public-finding-fix-rerun-input.schema.json"
          },
          "example": {
            "id": "finding_fix_rerun_input",
            "path": "examples/public-finding-fix-rerun-input.json"
          },
          "discriminator": {
            "field": "profile",
            "value": "finding_fix_rerun"
          }
        },
        {
          "id": "planning_reentry",
          "schema": {
            "schema_id": "guru-production-check-task-input-planning-reentry-1.0",
            "path": "schemas/public-planning-reentry-input.schema.json"
          },
          "example": {
            "id": "planning_reentry_input",
            "path": "examples/public-planning-reentry-input.json"
          },
          "discriminator": {
            "field": "profile",
            "value": "planning_reentry"
          }
        }
      ]
    },
    "invocation": {
      "command_id": "run-skill-command",
      "wrapper": "scripts/invoke.sh",
      "input_binding": {
        "kind": "structured_json",
        "profile_id": "initial_check"
      },
      "stdout_contract": "single_typed_exit",
      "error_schema": {
        "schema_id": "guru-production-check-task-invocation-error-1.0",
        "path": "schemas/public-invocation-error.schema.json"
      },
      "error_example": {
        "id": "invalid_public_input",
        "path": "examples/public-invocation-error.json"
      },
      "example_argv": [
        "--input",
        "examples/public-initial-check-input.json",
        "--owner-result",
        "examples/phase2-check.json"
      ]
    },
    "outputs": [
      {
        "exit_id": "passed",
        "schema": {
          "schema_id": "guru-production-check-task-output-passed-1.0",
          "path": "schemas/public-passed-output.schema.json"
        },
        "example": {
          "id": "passed_output",
          "path": "examples/public-passed-output.json"
        },
        "consumer_use_ids": [
          "project_passed"
        ]
      },
      {
        "exit_id": "implementation_required",
        "schema": {
          "schema_id": "guru-production-check-task-output-implementation-required-1.0",
          "path": "schemas/public-implementation-required-output.schema.json"
        },
        "example": {
          "id": "implementation_required_output",
          "path": "examples/public-implementation-required-output.json"
        },
        "consumer_use_ids": [
          "project_implementation_required"
        ]
      },
      {
        "exit_id": "planning_stale",
        "schema": {
          "schema_id": "guru-production-check-task-output-planning-stale-1.0",
          "path": "schemas/public-planning-stale-output.schema.json"
        },
        "example": {
          "id": "planning_stale_output",
          "path": "examples/public-planning-stale-output.json"
        },
        "consumer_use_ids": [
          "project_planning_stale"
        ]
      },
      {
        "exit_id": "blocked",
        "schema": {
          "schema_id": "guru-production-check-task-output-blocked-1.0",
          "path": "schemas/public-blocked-output.schema.json"
        },
        "example": {
          "id": "blocked_output",
          "path": "examples/public-blocked-output.json"
        },
        "consumer_use_ids": [
          "project_blocked"
        ]
      }
    ],
    "consumer_inputs": [
      {
        "id": "initial_commit_seed_input",
        "consumer": {
          "kind": "skill",
          "id": "guru-create-task-commit"
        },
        "payload_kind": "structured_json",
        "contract": {
          "kind": "skill_input_authoring_seed",
          "interface_path": "packages/guru-create-task-commit/interface.json",
          "input_kind": "structured_json",
          "profile_id": "initial_commit",
          "seed_fields": [
            "source_exit",
            "task_ref",
            "checked_head",
            "check_ref"
          ],
          "authoring_fields": [
            "profile",
            "mode",
            "message_intent",
            "path_authorizations",
            "semantic_review",
            "human_authorization",
            "exit_intent"
          ],
          "authoring_example": {
            "id": "initial_commit_authoring",
            "path": "examples/public-initial-commit-authoring.json"
          }
        }
      },
      {
        "id": "implementation_required_workflow_input",
        "consumer": {
          "kind": "workflow",
          "id": "guru-resume-implementation"
        },
        "payload_kind": "structured_json",
        "contract": {
          "kind": "json_schema",
          "schema_id": "guru-production-check-task-workflow-implementation-required-input-1.0",
          "path": "consumers/workflow/production/check-task-implementation-required.schema.json"
        }
      },
      {
        "id": "planning_stale_workflow_input",
        "consumer": {
          "kind": "workflow",
          "id": "guru-task-check-planning-router"
        },
        "payload_kind": "structured_json",
        "contract": {
          "kind": "json_schema",
          "schema_id": "guru-production-check-task-workflow-planning-stale-input-1.0",
          "path": "consumers/workflow/production/check-task-planning-stale.schema.json"
        }
      },
      {
        "id": "blocked_stop_input",
        "consumer": {
          "kind": "stop",
          "id": "task-check-blocked"
        },
        "payload_kind": "zero_payload"
      }
    ],
    "projections": [
      {
        "id": "project_passed",
        "exit_id": "passed",
        "consumer_input_id": "initial_commit_seed_input",
        "operation": "rename",
        "mappings": [
          {
            "source": "exit_id",
            "target": "source_exit"
          },
          {
            "source": "task_ref",
            "target": "task_ref"
          },
          {
            "source": "checked_head",
            "target": "checked_head"
          },
          {
            "source": "check_ref",
            "target": "check_ref"
          }
        ]
      },
      {
        "id": "project_implementation_required",
        "exit_id": "implementation_required",
        "consumer_input_id": "implementation_required_workflow_input",
        "operation": "direct"
      },
      {
        "id": "project_planning_stale",
        "exit_id": "planning_stale",
        "consumer_input_id": "planning_stale_workflow_input",
        "operation": "direct"
      },
      {
        "id": "project_blocked",
        "exit_id": "blocked",
        "consumer_input_id": "blocked_stop_input",
        "operation": "select",
        "mappings": []
      }
    ],
    "private_artifacts": [
      {
        "id": "phase2_check",
        "kind": "gate_evidence",
        "schema": {
          "schema_id": "https://github.com/castbox/guru-trellis/schemas/guru-phase2-check-2.0.json",
          "path": "schemas/phase2-check.schema.json"
        },
        "persistence": "task_local_tracked"
      }
    ]
  }
}
