{
  "$schema": "../../schemas/skill-interface-1.3.schema.json",
  "schema_version": "1.3",
  "id": "guru-clarify-requirements",
  "name": "guru-clarify-requirements",
  "description": "Clarify initial requirements, active-task scope changes, or explicit review requests through an evidence-first semantic loop with exact confirmation and typed exits.",
  "state": "active",
  "judgment_mode": "semantic",
  "modes": {
    "workflow": {
      "routing": "global_workflow",
      "entry_precondition_ids": [
        "runtime_dependency",
        "review_target",
        "context_evidence",
        "source_authority",
        "invocation_freshness"
      ]
    },
    "standalone": {
      "routing": "direct_discovery",
      "entry_precondition_ids": [
        "runtime_dependency",
        "review_target",
        "context_evidence",
        "source_authority",
        "invocation_freshness"
      ]
    }
  },
  "entry_preconditions": [
    {
      "id": "runtime_dependency",
      "evidence": "installed extension manifest, dispatcher, active package inventory and declared record/check runtime commands",
      "binding": "complete compatible Guru Team preset runtime",
      "freshness": "validated by run-skill-command before every runtime command"
    },
    {
      "id": "review_target",
      "evidence": "one current open/closed GitHub issue or side-effect-free proposed draft identity plus a checker-bound target disposition",
      "binding": "the exact requirements authority reviewed by the AI and the mutually exclusive retained, selected, reopened, follow-up, or complete outcome",
      "freshness": "target state/content, duplicate-search facts, every candidate decision and selected target remain unchanged through recording and checking"
    },
    {
      "id": "context_evidence",
      "evidence": "current guru-context-discovery-1.0 snapshot or explicit missing/stale evidence",
      "binding": "repository, current/history evidence and load-bearing decisions",
      "freshness": "current evidence is revalidated before clear; missing evidence returns needs_context"
    },
    {
      "id": "source_authority",
      "evidence": "live issue/draft facts plus exact target disposition, authority-impact classification, source-action preimage and post-mutation facts when applicable",
      "binding": "the selected issue or draft that fresh intake will read and every load-bearing clarification required by later implementation",
      "freshness": "AI rereads immediately before mutation and checker rereads declared target, duplicate and mutation facts"
    },
    {
      "id": "invocation_freshness",
      "evidence": "mode, invocation kind, caller-aware resume target, target/context/scope/action/payload/result digests and active-task bindings",
      "binding": "one current semantic review round and its validated legal continuation",
      "freshness": "all identities must still match at typed-exit validation"
    }
  ],
  "runtime_dependency": {
    "extension_id": "guru-team",
    "api_version": "1.0",
    "manifest_path": ".trellis/guru-team/extension.json",
    "dispatcher": "run-skill-command",
    "distribution": "guru-team-preset",
    "package_portability": "not-self-contained"
  },
  "ordered_stages": [
    "forward_behavior",
    "ai_review_gate",
    "conditional_human_confirmation",
    "recorder_validator",
    "typed_exit"
  ],
  "artifacts": [
    {
      "id": "requirements_clarification_example",
      "path": "examples/requirements-clarification.json"
    },
    {
      "id": "public_input_initial_change_request_example",
      "path": "examples/public-initial-change-request-input.json"
    },
    {
      "id": "public_input_active_task_scope_change_example",
      "path": "examples/public-active-task-scope-change-input.json"
    },
    {
      "id": "public_input_standalone_review_example",
      "path": "examples/public-standalone-review-input.json"
    },
    {
      "id": "public_invocation_error_example",
      "path": "examples/public-invocation-error.json"
    },
    {
      "id": "public_output_clear_example",
      "path": "examples/public-clear-output.json"
    },
    {
      "id": "public_output_needs_context_example",
      "path": "examples/public-needs-context-output.json"
    },
    {
      "id": "public_output_refresh_context_example",
      "path": "examples/public-refresh-context-output.json"
    },
    {
      "id": "public_output_retarget_context_example",
      "path": "examples/public-retarget-context-output.json"
    },
    {
      "id": "public_output_new_task_example",
      "path": "examples/public-new-task-output.json"
    },
    {
      "id": "public_output_blocked_example",
      "path": "examples/public-blocked-output.json"
    }
  ],
  "schemas": [
    {
      "id": "requirements_clarification_schema",
      "path": "schemas/requirements-clarification.schema.json"
    },
    {
      "id": "public_input_initial_change_request",
      "path": "schemas/public-initial-change-request-input.schema.json"
    },
    {
      "id": "public_input_active_task_scope_change",
      "path": "schemas/public-active-task-scope-change-input.schema.json"
    },
    {
      "id": "public_input_standalone_review",
      "path": "schemas/public-standalone-review-input.schema.json"
    },
    {
      "id": "public_input_aggregate",
      "path": "schemas/public-input.schema.json"
    },
    {
      "id": "public_invocation_error",
      "path": "schemas/public-invocation-error.schema.json"
    },
    {
      "id": "public_output_clear",
      "path": "schemas/public-clear-output.schema.json"
    },
    {
      "id": "public_output_needs_context",
      "path": "schemas/public-needs-context-output.schema.json"
    },
    {
      "id": "public_output_refresh_context",
      "path": "schemas/public-refresh-context-output.schema.json"
    },
    {
      "id": "public_output_retarget_context",
      "path": "schemas/public-retarget-context-output.schema.json"
    },
    {
      "id": "public_output_new_task",
      "path": "schemas/public-new-task-output.schema.json"
    },
    {
      "id": "public_output_blocked",
      "path": "schemas/public-blocked-output.schema.json"
    }
  ],
  "validators": [
    {
      "id": "clarification_recorder",
      "command": "scripts/record-requirements-clarification.sh",
      "runtime_command": "record-requirements-clarification",
      "objective_scope": "closed result normalization, derived proposal/action/content/result digests, stdout-only boundary and semantic-shape invariants"
    },
    {
      "id": "clarification_checker",
      "command": "scripts/check-requirements-clarification.sh",
      "runtime_command": "check-requirements-clarification",
      "objective_scope": "schema 2.0 and legacy-version rejection, digest recomputation, live source/context/target/duplicate freshness, exact target/action/scope confirmation, load-bearing authority persistence, mechanism disposition isolation, decision-trail linkage, authority-before-context-before-task-update re-entry and typed-exit invariants"
    },
    {
      "id": "public_invocation",
      "command": "scripts/invoke.sh",
      "runtime_command": "invoke-stage0-skill",
      "objective_scope": "Caller-owned input validation and deterministic typed-exit serialization after the owner closed loop"
    }
  ],
  "external_exits": [
    {
      "id": "clear",
      "evidence": "zero open questions, passed AI Review Gate, one current keep disposition for initial intake or current active-task authority, persisted load-bearing answers, exact required confirmation, and no unrefreshed mutation",
      "consumer": {
        "kind": "workflow",
        "id": "guru-requirements-clear-router"
      }
    },
    {
      "id": "needs_context",
      "evidence": "named load-bearing repository/current/history evidence is missing",
      "consumer": {
        "kind": "skill",
        "id": "guru-discover-change-context"
      }
    },
    {
      "id": "refresh_context",
      "evidence": "source/context binding is stale or an issue comment/body/reopen mutation succeeded",
      "consumer": {
        "kind": "skill",
        "id": "guru-sync-base"
      }
    },
    {
      "id": "retarget_context",
      "evidence": "a duplicate candidate open issue was exactly selected and validated as the new target",
      "consumer": {
        "kind": "skill",
        "id": "guru-sync-base"
      }
    },
    {
      "id": "new_task",
      "evidence": "an independent delivery unit has a reviewed side-effect-free new issue draft and any active task preserved its classification trail before fresh re-entry",
      "consumer": {
        "kind": "workflow",
        "id": "guru-full-task-intake-chain"
      }
    },
    {
      "id": "blocked",
      "evidence": "load-bearing refusal, unobtainable evidence, conflict, checker-bound target-complete disposition, or blocked semantic gate",
      "consumer": {
        "kind": "stop",
        "id": "requirements-clarification-blocked"
      }
    }
  ],
  "reentry": {
    "identity": "mode, invocation kind, review target, target disposition, duplicate candidates, context, clarification authority impacts, scope proposals, source actions, confirmation, active-task evidence and derived content identity",
    "freshness": "clear/new_task/retarget_context is accepted only while every target/duplicate/authority/context/task binding remains current; GitHub authority mutation refreshes context first, context generated_at is not earlier than authority updated_at, task update binds that current digest, and no second context digest change is required",
    "stale_behavior": "fail_closed"
  },
  "tests": [
    "tests/test_contract.py"
  ],
  "platform_destinations": [
    "shared",
    "codex",
    "cursor",
    "claude"
  ],
  "public_contracts": {
    "input": {
      "kind": "structured_json",
      "aggregate_schema": {
