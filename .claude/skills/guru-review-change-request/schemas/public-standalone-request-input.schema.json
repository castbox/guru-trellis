    },
    "target_locator": {
      "type": "string",
      "minLength": 1
    },
    "context_locator": {
      "type": "string",
      "minLength": 1
    },
    "clarity_locator": {
      "type": "string",
      "minLength": 1
    },
    "wording_locator": {
      "type": "string",
      "minLength": 1
    },
    "continuation_id": {
      "type": "string",
      "minLength": 1
    }
  }
