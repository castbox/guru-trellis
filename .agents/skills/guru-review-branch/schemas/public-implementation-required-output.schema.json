{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-production-review-branch-output-implementation-required-1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["exit_id", "task_ref", "reviewed_head", "finding_refs"],
  "properties": {
    "exit_id": {"const": "implementation_required"},
    "task_ref": {"type": "string", "pattern": "^\\.trellis/tasks/[A-Za-z0-9._/-]+$"},
    "reviewed_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "finding_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
