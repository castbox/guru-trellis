{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-production-approve-task-plan-input-initial-review-1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "mode",
    "task_ref",
    "authority_refs",
    "provenance_review",
    "adequacy_review",
    "unusual_scenario_dispositions",
    "confirmation",
    "ai_review_gate",
    "exit_intent",
    "source_exit"
  ],
  "properties": {
    "profile": {
      "const": "initial_review"
    },
    "mode": {
      "type": "string",
      "enum": [
        "workflow",
        "standalone"
      ]
    },
    "task_ref": {
      "type": "string",
      "pattern": "^\\.trellis/tasks/[A-Za-z0-9._/-]+$"
    },
    "authority_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "provenance_review": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "adequacy_review": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unusual_scenario_dispositions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "confirmed",
            "not_required",
            "refused"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ai_review_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "revision_required",
            "clarify_scope",
            "blocked"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "exit_intent": {
      "type": "string",
      "enum": [
        "approved",
        "revision_required",
        "clarify_scope",
        "blocked"
      ]
    },
    "source_exit": {
      "const": "planning_ready"
    }
  }
}
