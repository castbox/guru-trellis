      ]
    },
    "target_locator": {
      "type": "string",
      "minLength": 1
    },
    "context_locator": {
      "type": "string",
      "minLength": 1
    },
    "continuation_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
