{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-team-production-migration-manifest-1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_id",
    "schema_version",
    "activation_unit_id",
    "interface_schema_id",
    "registry_schema_id",
    "eval_schema_id",
    "activation_policy",
    "skill_ids",
    "legacy_skill_ids",
    "authoring_seed_edges",
    "skills"
  ],
  "properties": {
    "$schema": {"const": "../schemas/production-migration-manifest.schema.json"},
    "schema_id": {"const": "guru-team-production-migration-manifest-1.0"},
    "schema_version": {"const": "1.0"},
    "activation_unit_id": {"const": "production-minimal-handoff-v1"},
    "interface_schema_id": {"const": "guru-team-skill-interface-1.3"},
    "registry_schema_id": {"const": "guru-team-skill-registry-1.1"},
    "eval_schema_id": {"const": "guru-team-skill-evals-1.0"},
    "activation_policy": {"const": "preset_transaction"},
    "skill_ids": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^guru-[a-z0-9]+(?:-[a-z0-9]+)+$"}
    },
    "legacy_skill_ids": {
      "type": "array",
      "maxItems": 0,
      "items": {"type": "string"}
    },
    "authoring_seed_edges": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/authoringSeedEdge"}
    },
    "skills": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"$ref": "#/$defs/skill"}
    }
  },
  "$defs": {
    "localId": {"type": "string", "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"},
    "skillId": {"type": "string", "pattern": "^guru-[a-z0-9]+(?:-[a-z0-9]+)+$"},
    "authoringSeedEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_skill_id",
        "exit_id",
        "consumer_skill_id",
        "profile_id",
        "consumer_input_id",
        "projection_id",
        "authoring_example_id"
      ],
      "properties": {
        "producer_skill_id": {"$ref": "#/$defs/skillId"},
        "exit_id": {"$ref": "#/$defs/localId"},
        "consumer_skill_id": {"$ref": "#/$defs/skillId"},
        "profile_id": {"$ref": "#/$defs/localId"},
        "consumer_input_id": {"$ref": "#/$defs/localId"},
        "projection_id": {"$ref": "#/$defs/localId"},
        "authoring_example_id": {"$ref": "#/$defs/localId"}
      }
    },
    "exitBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exit_id",
        "output_schema_id",
        "output_example_id",
        "consumer_input_id",
        "projection_id",
        "eval_case_ids"
      ],
      "properties": {
        "exit_id": {"$ref": "#/$defs/localId"},
        "output_schema_id": {"type": "string", "minLength": 1},
        "output_example_id": {"$ref": "#/$defs/localId"},
        "consumer_input_id": {"$ref": "#/$defs/localId"},
        "projection_id": {"$ref": "#/$defs/localId"},
        "eval_case_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/localId"}
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "input_kind",
        "input_profile_ids",
        "profile_case_bindings",
        "exit_bindings",
        "private_artifact_ids",
        "eval_case_ids"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/skillId"},
        "input_kind": {"const": "structured_json"},
        "input_profile_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/localId"}
        },
        "profile_case_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/profileBinding"}
        },
        "exit_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/exitBinding"}
        },
        "private_artifact_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/localId"}
        },
        "eval_case_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/localId"}
        }
      }
    },
    "profileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "eval_case_ids"],
      "properties": {
        "profile_id": {"$ref": "#/$defs/localId"},
        "eval_case_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/localId"}
        }
      }
    }
  }
}
