{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-team-stage0-migration-manifest-1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_id",
    "schema_version",
    "activation_unit_id",
    "interface_schema_id",
    "registry_schema_id",
    "eval_schema_id",
    "activation_policy",
    "skill_ids",
    "legacy_skill_ids",
    "skills"
  ],
  "properties": {
    "$schema": {
      "const": "../schemas/stage0-migration-manifest.schema.json"
    },
    "schema_id": {
      "const": "guru-team-stage0-migration-manifest-1.0"
    },
    "schema_version": {
      "const": "1.0"
    },
    "activation_unit_id": {
      "const": "stage0-minimal-handoff-v1"
    },
    "interface_schema_id": {
      "const": "guru-team-skill-interface-1.3"
    },
    "registry_schema_id": {
      "const": "guru-team-skill-registry-1.1"
    },
    "eval_schema_id": {
      "const": "guru-team-skill-evals-1.0"
    },
    "activation_policy": {
      "const": "preset_transaction"
    },
    "skill_ids": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^guru-[a-z0-9]+(?:-[a-z0-9]+)+$"
      }
    },
    "legacy_skill_ids": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^guru-[a-z0-9]+(?:-[a-z0-9]+)+$"
      }
    },
    "skills": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/skill"
      }
    }
  },
  "$defs": {
    "exitBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exit_id",
        "output_schema_id",
        "consumer_input_id",
        "projection_id",
        "eval_case_ids"
      ],
      "properties": {
        "exit_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
        },
        "output_schema_id": {
          "type": "string",
          "minLength": 1
        },
        "consumer_input_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
        },
        "projection_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
        },
        "eval_case_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
          }
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "input_kind",
        "input_profile_ids",
        "profile_case_bindings",
        "exit_bindings",
        "private_artifact_ids",
        "eval_case_ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^guru-[a-z0-9]+(?:-[a-z0-9]+)+$"
        },
        "input_kind": {
          "enum": [
            "structured_json",
            "scalar_cli"
          ]
        },
        "input_profile_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
          }
        },
        "profile_case_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/profileBinding"
          }
        },
        "exit_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/exitBinding"
          }
        },
        "private_artifact_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
          }
        },
        "eval_case_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
          }
        }
      }
    },
    "profileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "eval_case_ids"
      ],
      "properties": {
        "profile_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
        },
        "eval_case_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
          }
        }
      }
    }
  }
}
