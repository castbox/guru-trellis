{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/castbox/guru-trellis/schemas/guru-team-skill-interface-1.2.json",
  "title": "Guru Team closed-loop workflow skill interface",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "id", "name", "description", "state", "judgment_mode", "modes", "entry_preconditions", "runtime_dependency", "ordered_stages", "artifacts", "schemas", "validators", "external_exits", "reentry", "tests", "platform_destinations"],
  "properties": {
    "$schema": {"const": "../../schemas/skill-interface.schema.json"},
    "schema_version": {"const": "1.2"},
    "id": {"type": "string", "pattern": "^guru-[a-z0-9]+(?:-[a-z0-9]+)+$"},
    "name": {"type": "string", "pattern": "^guru-[a-z0-9]+(?:-[a-z0-9]+)+$"},
    "description": {"type": "string", "minLength": 1},
    "state": {"const": "active"},
    "judgment_mode": {"enum": ["semantic", "deterministic"]},
    "modes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow", "standalone"],
      "properties": {
        "workflow": {"$ref": "#/$defs/workflowMode"},
        "standalone": {"$ref": "#/$defs/standaloneMode"}
      }
    },
    "entry_preconditions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/precondition"}},
    "runtime_dependency": {"$ref": "#/$defs/runtimeDependency"},
    "ordered_stages": {"type": "array", "items": {"type": "string"}},
    "artifacts": {"type": "array", "items": {"$ref": "#/$defs/pathItem"}},
    "schemas": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/pathItem"}},
    "validators": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/validator"}},
    "external_exits": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/exit"}},
    "reentry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "freshness", "stale_behavior"],
      "properties": {
        "identity": {"type": "string", "minLength": 1},
        "freshness": {"type": "string", "minLength": 1},
        "stale_behavior": {"const": "fail_closed"}
      }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$))tests/.+$"}
    },
    "platform_destinations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["shared", "codex", "cursor", "claude"]}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"judgment_mode": {"const": "semantic"}}, "required": ["judgment_mode"]},
      "then": {"properties": {"ordered_stages": {"const": ["forward_behavior", "ai_review_gate", "conditional_human_confirmation", "recorder_validator", "typed_exit"]}}}
    },
    {
      "if": {"properties": {"judgment_mode": {"const": "deterministic"}}, "required": ["judgment_mode"]},
      "then": {"properties": {"ordered_stages": {"const": ["forward_behavior", "recorder_validator", "typed_exit"]}}}
    }
  ],
  "$defs": {
    "workflowMode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routing", "entry_precondition_ids"],
      "properties": {
        "routing": {"const": "global_workflow"},
        "entry_precondition_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}}
      }
    },
    "standaloneMode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routing", "entry_precondition_ids"],
      "properties": {
        "routing": {"const": "direct_discovery"},
        "entry_precondition_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}}
      }
    },
    "runtimeDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extension_id", "api_version", "manifest_path", "dispatcher", "distribution", "package_portability"],
      "properties": {
        "extension_id": {"const": "guru-team"},
        "api_version": {"const": "1.0"},
        "manifest_path": {"const": ".trellis/guru-team/extension.json"},
        "dispatcher": {"const": "run-skill-command"},
        "distribution": {"const": "guru-team-preset"},
        "package_portability": {"const": "not-self-contained"}
      }
    },
    "precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "evidence", "binding", "freshness"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "evidence": {"type": "string", "minLength": 1},
        "binding": {"type": "string", "minLength": 1},
        "freshness": {"type": "string", "minLength": 1}
      }
    },
    "pathItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command", "runtime_command", "objective_scope"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "command": {"type": "string", "minLength": 1},
        "runtime_command": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "objective_scope": {"type": "string", "minLength": 1}
      }
    },
    "exit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "evidence", "consumer"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"},
        "evidence": {"type": "string", "minLength": 1},
        "consumer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id"],
          "properties": {
            "kind": {"enum": ["workflow", "skill", "stop"]},
            "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
          }
        }
      }
    }
  }
}
