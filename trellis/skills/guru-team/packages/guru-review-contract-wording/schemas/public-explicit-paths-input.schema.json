{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-stage0-review-contract-wording-input-explicit-paths-1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "source_exit",
    "mode",
    "paths",
    "continuation_id"
  ],
  "properties": {
    "profile": {
      "const": "explicit_paths"
    },
    "source_exit": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "workflow",
        "standalone"
      ]
    },
    "paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "continuation_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
