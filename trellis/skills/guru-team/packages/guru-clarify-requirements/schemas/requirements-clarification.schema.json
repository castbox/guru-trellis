{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/castbox/guru-trellis/schemas/guru-requirements-clarification-1.0.json",
  "title": "Guru Team requirements clarification result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "skill_id", "generated_at", "mode", "typed_exit",
    "invocation_context", "review_target", "context_evidence",
    "confirmed_facts", "repository_answerable_questions",
    "clarification_rounds", "open_questions", "scope_proposals",
    "source_actions", "human_confirmation", "mutation_results",
    "active_task_evidence", "ai_review_gate", "affected_contracts",
    "content_identity", "reason", "consumer", "error"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "skill_id": {"const": "guru-clarify-requirements"},
    "generated_at": {"type": "string", "format": "date-time"},
    "mode": {"enum": ["workflow", "standalone"]},
    "typed_exit": {"enum": ["clear", "needs_context", "refresh_context", "new_task", "blocked"]},
    "invocation_context": {"$ref": "#/$defs/invocationContext"},
    "review_target": {"$ref": "#/$defs/reviewTarget"},
    "context_evidence": {"$ref": "#/$defs/contextEvidence"},
    "confirmed_facts": {"type": "array", "items": {"$ref": "#/$defs/confirmedFact"}},
    "repository_answerable_questions": {"type": "array", "items": {"$ref": "#/$defs/repositoryQuestion"}},
    "clarification_rounds": {"type": "array", "items": {"$ref": "#/$defs/clarificationRound"}},
    "open_questions": {"$ref": "#/$defs/idList"},
    "scope_proposals": {"type": "array", "items": {"$ref": "#/$defs/scopeProposal"}},
    "source_actions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/sourceAction"}},
    "human_confirmation": {"$ref": "#/$defs/humanConfirmation"},
    "mutation_results": {"type": "array", "items": {"$ref": "#/$defs/mutationResult"}},
    "active_task_evidence": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/activeTaskEvidence"}]},
    "ai_review_gate": {"$ref": "#/$defs/aiGate"},
    "affected_contracts": {"$ref": "#/$defs/stringList"},
    "content_identity": {"$ref": "#/$defs/contentIdentity"},
    "reason": {"$ref": "#/$defs/nonEmpty"},
    "consumer": {"$ref": "#/$defs/consumer"},
    "error": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/error"}]}
  },
  "allOf": [
    {
      "if": {"properties": {"typed_exit": {"const": "clear"}}, "required": ["typed_exit"]},
      "then": {
        "properties": {
          "open_questions": {"maxItems": 0},
          "context_evidence": {"properties": {"status": {"const": "current"}}},
          "ai_review_gate": {"properties": {"status": {"const": "passed"}}},
          "consumer": {"const": {"kind": "workflow", "id": "guru-requirements-clear-router"}},
          "error": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"typed_exit": {"const": "needs_context"}}, "required": ["typed_exit"]},
      "then": {
        "properties": {
          "context_evidence": {"properties": {"status": {"const": "missing"}}},
          "consumer": {"const": {"kind": "skill", "id": "guru-discover-change-context"}}
        }
      }
    },
    {
      "if": {"properties": {"typed_exit": {"const": "refresh_context"}}, "required": ["typed_exit"]},
      "then": {"properties": {"consumer": {"const": {"kind": "skill", "id": "guru-sync-base"}}}}
    },
    {
      "if": {"properties": {"typed_exit": {"const": "new_task"}}, "required": ["typed_exit"]},
      "then": {
        "properties": {
          "consumer": {"const": {"kind": "workflow", "id": "guru-full-task-intake-chain"}},
          "ai_review_gate": {"properties": {"status": {"const": "passed"}}},
          "error": {"type": "null"},
          "source_actions": {"contains": {"properties": {"kind": {"const": "new_issue_draft"}}, "required": ["kind"]}}
        }
      }
    },
    {
      "if": {"properties": {"typed_exit": {"const": "blocked"}}, "required": ["typed_exit"]},
      "then": {
        "properties": {
          "ai_review_gate": {"properties": {"status": {"const": "blocked"}}},
          "consumer": {"const": {"kind": "stop", "id": "requirements-clarification-blocked"}},
          "error": {"$ref": "#/$defs/error"}
        }
      }
    },
    {
      "if": {"properties": {"ai_review_gate": {"properties": {"status": {"const": "blocked"}}, "required": ["status"]}}, "required": ["ai_review_gate"]},
      "then": {"properties": {"typed_exit": {"const": "blocked"}}}
    },
    {
      "if": {"properties": {"invocation_context": {"properties": {"kind": {"enum": ["initial_issue", "proposed_draft", "standalone_review"]}}, "required": ["kind"]}}, "required": ["invocation_context"]},
      "then": {"properties": {"active_task_evidence": {"type": "null"}}}
    },
    {
      "if": {
        "properties": {
          "invocation_context": {"properties": {"kind": {"const": "active_task_scope_change"}}, "required": ["kind"]},
          "typed_exit": {"enum": ["clear", "new_task"]}
        },
        "required": ["invocation_context", "typed_exit"]
      },
      "then": {
        "properties": {
          "scope_proposals": {
            "type": "array", "minItems": 1,
            "items": {
              "allOf": [
                {"$ref": "#/$defs/scopeProposal"},
                {"properties": {"decision": {"enum": ["accepted_current", "related", "followup", "new_task", "out_of_scope", "mechanism_removed", "mechanism_replaced"]}}}
              ]
            }
          },
          "active_task_evidence": {"$ref": "#/$defs/activeTaskEvidence"}
        }
      }
    },
    {
      "if": {"properties": {"invocation_context": {"properties": {"kind": {"enum": ["initial_issue", "proposed_draft"]}}, "required": ["kind"]}}, "required": ["invocation_context"]},
      "then": {"properties": {"invocation_context": {"properties": {"resume_target": {"const": "guru-review-contract-wording"}}}}}
    },
    {
      "if": {"properties": {"invocation_context": {"properties": {"kind": {"const": "standalone_review"}}, "required": ["kind"]}}, "required": ["invocation_context"]},
      "then": {"properties": {"invocation_context": {"properties": {"resume_target": {"const": "guru-standalone-caller"}}}}}
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nonEmpty": {"type": "string", "minLength": 1, "maxLength": 8192, "pattern": "^[^\\u0000-\\u0008\\u000b\\u000c\\u000e-\\u001f\\u007f]+$"},
    "identifier": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,127}$"},
    "portablePath": {"type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
    "stringList": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
    "idList": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/identifier"}},
    "invocationContext": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "caller", "task_locator", "resume_target"],
      "properties": {
        "kind": {"enum": ["initial_issue", "proposed_draft", "active_task_scope_change", "standalone_review"]},
        "caller": {"$ref": "#/$defs/nonEmpty"},
        "task_locator": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/portablePath"}]},
        "resume_target": {
          "enum": [
            "guru-review-contract-wording", "guru-standalone-caller",
            "guru-active-task-planning-review", "guru-resume-requirement-exploration",
            "guru-resume-implementation", "guru-resume-phase2-check",
            "guru-resume-spec-evaluation", "guru-resume-task-commit",
            "guru-resume-branch-review"
          ]
        }
      }
    },
    "reviewTarget": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "repo", "issue_number", "url", "state", "updated_at", "body_sha256", "facts_sha256"],
      "properties": {
        "kind": {"enum": ["issue", "draft"]},
        "repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "issue_number": {"oneOf": [{"type": "null"}, {"type": "integer", "minimum": 1}]},
        "url": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*$"}]},
        "state": {"enum": ["open", "closed", "draft"]},
        "updated_at": {"oneOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
        "body_sha256": {"$ref": "#/$defs/sha256"},
        "facts_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "contextEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "schema_id", "snapshot_sha256", "evidence_refs", "missing_reason"],
      "properties": {
        "status": {"enum": ["current", "missing", "stale"]},
        "schema_id": {"oneOf": [{"type": "null"}, {"const": "guru-context-discovery-1.0"}]},
        "snapshot_sha256": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha256"}]},
        "evidence_refs": {"$ref": "#/$defs/stringList"},
        "missing_reason": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/nonEmpty"}]}
      }
    },
    "confirmedFact": {
      "type": "object", "additionalProperties": false,
      "required": ["fact_id", "summary", "evidence_refs", "affected_contracts"],
      "properties": {
        "fact_id": {"$ref": "#/$defs/identifier"},
        "summary": {"$ref": "#/$defs/nonEmpty"},
        "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
        "affected_contracts": {"$ref": "#/$defs/stringList"}
      }
    },
    "repositoryQuestion": {
      "type": "object", "additionalProperties": false,
      "required": ["question_id", "question", "status", "evidence_refs", "answer_summary", "missing_reason"],
      "properties": {
        "question_id": {"$ref": "#/$defs/identifier"},
        "question": {"$ref": "#/$defs/nonEmpty"},
        "status": {"enum": ["pending", "answered", "not_answerable"]},
        "evidence_refs": {"$ref": "#/$defs/stringList"},
        "answer_summary": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/nonEmpty"}]},
        "missing_reason": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/nonEmpty"}]}
      },
      "allOf": [
        {"if": {"properties": {"status": {"const": "answered"}}, "required": ["status"]}, "then": {"properties": {"evidence_refs": {"minItems": 1}, "answer_summary": {"$ref": "#/$defs/nonEmpty"}, "missing_reason": {"type": "null"}}}},
        {"if": {"properties": {"status": {"const": "not_answerable"}}, "required": ["status"]}, "then": {"properties": {"evidence_refs": {"minItems": 1}, "answer_summary": {"type": "null"}, "missing_reason": {"$ref": "#/$defs/nonEmpty"}}}}
      ]
    },
    "clarificationRound": {
      "type": "object", "additionalProperties": false,
      "required": ["round_id", "question_id", "atomic_group_id", "atomic_group_reason", "category", "question", "answer_summary", "answer_status", "affected_contracts", "opened_question_ids", "closed_question_ids"],
      "properties": {
        "round_id": {"$ref": "#/$defs/identifier"},
        "question_id": {"$ref": "#/$defs/identifier"},
        "atomic_group_id": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/identifier"}]},
        "atomic_group_reason": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/nonEmpty"}]},
        "category": {"enum": ["product_intent", "scope_risk_decision"]},
        "question": {"$ref": "#/$defs/nonEmpty"},
        "answer_summary": {"$ref": "#/$defs/nonEmpty"},
        "answer_status": {"enum": ["complete", "partial", "refused"]},
        "affected_contracts": {"$ref": "#/$defs/stringList"},
        "opened_question_ids": {"$ref": "#/$defs/idList"},
        "closed_question_ids": {"$ref": "#/$defs/idList"}
      },
      "allOf": [
        {"if": {"properties": {"answer_status": {"const": "partial"}}, "required": ["answer_status"]}, "then": {"properties": {"closed_question_ids": {"maxItems": 0}}}},
        {"if": {"properties": {"atomic_group_id": {"type": "null"}}, "required": ["atomic_group_id"]}, "then": {"properties": {"atomic_group_reason": {"type": "null"}}}, "else": {"properties": {"atomic_group_reason": {"$ref": "#/$defs/nonEmpty"}}}}
      ]
    },
    "scopeProposal": {
      "type": "object", "additionalProperties": false,
      "required": ["proposal_id", "scenario", "trigger_evidence", "proposed_contracts", "cost", "alternatives", "consequence_if_omitted", "origin_requirement_status", "optional_mechanism_origin", "decision", "proposal_digest", "confirmation_ref"],
      "properties": {
        "proposal_id": {"$ref": "#/$defs/identifier"},
        "scenario": {"$ref": "#/$defs/nonEmpty"},
        "trigger_evidence": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
        "proposed_contracts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
        "cost": {"$ref": "#/$defs/nonEmpty"},
        "alternatives": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
        "consequence_if_omitted": {"$ref": "#/$defs/nonEmpty"},
        "origin_requirement_status": {"enum": ["explicit", "necessary_correctness", "confirmed_expansion", "unconfirmed_expansion"]},
        "optional_mechanism_origin": {"type": "boolean"},
        "decision": {"enum": ["pending", "accepted_current", "related", "followup", "new_task", "out_of_scope", "mechanism_removed", "mechanism_replaced"]},
        "proposal_digest": {"$ref": "#/$defs/sha256"},
        "confirmation_ref": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/identifier"}]}
      },
      "allOf": [
        {
          "if": {"properties": {"decision": {"enum": ["mechanism_removed", "mechanism_replaced"]}}, "required": ["decision"]},
          "then": {"properties": {"optional_mechanism_origin": {"const": true}, "confirmation_ref": {"type": "null"}}}
        },
        {
          "if": {"properties": {"optional_mechanism_origin": {"const": true}}, "required": ["optional_mechanism_origin"]},
          "then": {"properties": {"decision": {"enum": ["pending", "mechanism_removed", "mechanism_replaced"]}}}
        }
      ]
    },
    "sourceAction": {
      "type": "object", "additionalProperties": false,
      "required": ["action_id", "kind", "target", "payload", "preimage_sha256", "payload_sha256", "action_digest", "status", "mutation_evidence"],
      "properties": {
        "action_id": {"$ref": "#/$defs/identifier"},
        "kind": {"enum": ["none", "issue_comment", "issue_body_edit", "proposed_draft_update", "new_issue_draft", "active_task_scope_update"]},
        "target": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/githubIssueActionTarget"}, {"$ref": "#/$defs/draftActionTarget"}, {"$ref": "#/$defs/activeTaskActionTarget"}]},
        "payload": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/bodyActionPayload"}, {"$ref": "#/$defs/draftActionPayload"}, {"$ref": "#/$defs/activeTaskActionPayload"}]},
        "preimage_sha256": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha256"}]},
        "payload_sha256": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha256"}]},
        "action_digest": {"$ref": "#/$defs/sha256"},
        "status": {"enum": ["not_required", "pending", "draft_ready", "executed", "validated"]},
        "mutation_evidence": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/githubMutationEvidence"}, {"$ref": "#/$defs/activeTaskMutationEvidence"}]}
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "none"}}, "required": ["kind"]},
          "then": {"properties": {"target": {"type": "null"}, "payload": {"type": "null"}, "preimage_sha256": {"type": "null"}, "payload_sha256": {"type": "null"}, "status": {"const": "not_required"}, "mutation_evidence": {"type": "null"}}}
        },
        {
          "if": {"properties": {"kind": {"enum": ["issue_comment", "issue_body_edit"]}}, "required": ["kind"]},
          "then": {
            "properties": {"target": {"$ref": "#/$defs/githubIssueActionTarget"}, "payload": {"$ref": "#/$defs/bodyActionPayload"}, "preimage_sha256": {"$ref": "#/$defs/sha256"}, "payload_sha256": {"$ref": "#/$defs/sha256"}, "status": {"enum": ["pending", "executed", "validated"]}},
            "allOf": [{"if": {"properties": {"status": {"const": "pending"}}, "required": ["status"]}, "then": {"properties": {"mutation_evidence": {"type": "null"}}}, "else": {"properties": {"mutation_evidence": {"$ref": "#/$defs/githubMutationEvidence"}}}}]
          }
        },
        {
          "if": {"properties": {"kind": {"const": "proposed_draft_update"}}, "required": ["kind"]},
          "then": {"properties": {"target": {"$ref": "#/$defs/draftActionTarget"}, "payload": {"$ref": "#/$defs/draftActionPayload"}, "preimage_sha256": {"$ref": "#/$defs/sha256"}, "payload_sha256": {"$ref": "#/$defs/sha256"}, "status": {"const": "validated"}, "mutation_evidence": {"type": "null"}}}
        },
        {
          "if": {"properties": {"kind": {"const": "new_issue_draft"}}, "required": ["kind"]},
          "then": {"properties": {"target": {"$ref": "#/$defs/draftActionTarget"}, "payload": {"$ref": "#/$defs/draftActionPayload"}, "preimage_sha256": {"type": "null"}, "payload_sha256": {"$ref": "#/$defs/sha256"}, "status": {"const": "draft_ready"}, "mutation_evidence": {"type": "null"}}}
        },
        {
          "if": {"properties": {"kind": {"const": "active_task_scope_update"}}, "required": ["kind"]},
          "then": {"properties": {"target": {"$ref": "#/$defs/activeTaskActionTarget"}, "payload": {"$ref": "#/$defs/activeTaskActionPayload"}, "preimage_sha256": {"$ref": "#/$defs/sha256"}, "payload_sha256": {"$ref": "#/$defs/sha256"}, "status": {"enum": ["executed", "validated"]}, "mutation_evidence": {"$ref": "#/$defs/activeTaskMutationEvidence"}}}
        }
      ]
    },
    "githubIssueActionTarget": {
      "type": "object", "additionalProperties": false,
      "required": ["repo", "issue_number"],
      "properties": {"repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"}, "issue_number": {"type": "integer", "minimum": 1}}
    },
    "draftActionTarget": {
      "type": "object", "additionalProperties": false,
      "required": ["repo"],
      "properties": {"repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"}}
    },
    "activeTaskActionTarget": {
      "type": "object", "additionalProperties": false,
      "required": ["task_locator"],
      "properties": {"task_locator": {"$ref": "#/$defs/portablePath"}}
    },
    "bodyActionPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["body"],
      "properties": {"body": {"$ref": "#/$defs/nonEmpty"}}
    },
    "draftActionPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["title", "body"],
      "properties": {"title": {"$ref": "#/$defs/nonEmpty"}, "body": {"$ref": "#/$defs/nonEmpty"}}
    },
    "githubMutationEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["source"],
      "properties": {"source": {"const": "ai-reviewed-gh"}}
    },
    "activeTaskMutationEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["source"],
      "properties": {"source": {"const": "confirmed-task-local-update"}}
    },
    "humanConfirmation": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "confirmation_kind", "action_digest", "proposal_digests", "confirmed_actions", "confirmer", "confirmed_at", "evidence_summary"],
      "properties": {
        "status": {"enum": ["not_required", "confirmed", "refused"]},
        "confirmation_kind": {"enum": ["none", "exact_source_action", "exact_scope_proposal", "exact_source_action_and_scope"]},
        "action_digest": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha256"}]},
        "proposal_digests": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}},
        "confirmed_actions": {"$ref": "#/$defs/idList"},
        "confirmer": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/nonEmpty"}]},
        "confirmed_at": {"oneOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
        "evidence_summary": {"$ref": "#/$defs/nonEmpty"}
      }
    },
    "mutationResult": {
      "type": "object", "additionalProperties": false,
      "required": ["action_id", "kind", "status", "url", "state", "updated_at", "content_sha256", "action_digest", "facts_sha256"],
      "properties": {
        "action_id": {"$ref": "#/$defs/identifier"},
        "kind": {"enum": ["issue_comment", "issue_body_edit", "proposed_draft_update", "active_task_scope_update"]},
        "status": {"const": "succeeded"},
        "url": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/nonEmpty"}]},
        "state": {"enum": ["open", "closed", "draft", "task_local"]},
        "updated_at": {"oneOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "action_digest": {"$ref": "#/$defs/sha256"},
        "facts_sha256": {"$ref": "#/$defs/sha256"}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "issue_comment"}}, "required": ["kind"]}, "then": {"properties": {"url": {"type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*#issuecomment-[1-9][0-9]*$"}, "state": {"enum": ["open", "closed"]}, "updated_at": {"type": "string", "format": "date-time"}}}},
        {"if": {"properties": {"kind": {"const": "issue_body_edit"}}, "required": ["kind"]}, "then": {"properties": {"url": {"type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*$"}, "state": {"enum": ["open", "closed"]}, "updated_at": {"type": "string", "format": "date-time"}}}},
        {"if": {"properties": {"kind": {"const": "proposed_draft_update"}}, "required": ["kind"]}, "then": {"properties": {"url": {"type": "null"}, "state": {"const": "draft"}, "updated_at": {"type": "null"}}}},
        {"if": {"properties": {"kind": {"const": "active_task_scope_update"}}, "required": ["kind"]}, "then": {"properties": {"url": {"type": "null"}, "state": {"const": "task_local"}, "updated_at": {"type": "null"}}}}
      ]
    },
    "activeTaskEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["task_locator", "github_authority_facts_sha256", "ledger", "planning_documents", "stale_downstream_evidence", "review_evidence", "decision_trail", "reentry_owners"],
      "properties": {
        "task_locator": {"$ref": "#/$defs/portablePath"},
        "github_authority_facts_sha256": {"$ref": "#/$defs/sha256"},
        "ledger": {"$ref": "#/$defs/fileEvidence"},
        "planning_documents": {"$ref": "#/$defs/planningDocumentEvidence"},
        "stale_downstream_evidence": {"$ref": "#/$defs/staleDownstreamEvidence"},
        "review_evidence": {"$ref": "#/$defs/reviewEvidence"},
        "decision_trail": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/decisionTrail"}]},
        "reentry_owners": {"$ref": "#/$defs/reentryOwners"}
      }
    },
    "activeTaskActionPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["github_authority_facts_sha256", "ledger", "planning_documents", "stale_downstream_evidence", "review_evidence", "decision_trail", "reentry_owners"],
      "properties": {
        "github_authority_facts_sha256": {"$ref": "#/$defs/sha256"},
        "ledger": {"$ref": "#/$defs/fileEvidence"},
        "planning_documents": {"$ref": "#/$defs/planningDocumentEvidence"},
        "stale_downstream_evidence": {"$ref": "#/$defs/staleDownstreamEvidence"},
        "review_evidence": {"$ref": "#/$defs/reviewEvidence"},
        "decision_trail": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/decisionTrail"}]},
        "reentry_owners": {"$ref": "#/$defs/reentryOwners"}
      }
    },
    "planningDocumentEvidence": {
      "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true,
      "items": {"$ref": "#/$defs/fileEvidence"}
    },
    "staleDownstreamEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["planning_approval_sha256", "phase2_check_sha256", "branch_review_sha256"],
      "properties": {
        "planning_approval_sha256": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha256"}]},
        "phase2_check_sha256": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha256"}]},
        "branch_review_sha256": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/sha256"}]}
      }
    },
    "reviewEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "artifact"],
      "properties": {
        "status": {"enum": ["not_started", "stale"]},
        "artifact": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/fileEvidence"}]}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "not_started"}}, "required": ["status"]},
          "then": {"properties": {"artifact": {"type": "null"}}},
          "else": {"properties": {"artifact": {"$ref": "#/$defs/fileEvidence"}}}
        }
      ]
    },
    "decisionTrail": {
      "type": "object", "additionalProperties": false,
      "required": ["trail_id", "proposal_decisions", "user_decision", "github_authority", "context_before_task_update_sha256", "planning_documents", "stale_downstream_evidence", "review_evidence", "reentry_owners", "interrupted_resume_target"],
      "properties": {
        "trail_id": {"$ref": "#/$defs/identifier"},
        "proposal_decisions": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"$ref": "#/$defs/proposalDecision"}
        },
        "user_decision": {"$ref": "#/$defs/userDecisionEvidence"},
        "github_authority": {"$ref": "#/$defs/githubDecisionAuthority"},
        "context_before_task_update_sha256": {"$ref": "#/$defs/sha256"},
        "planning_documents": {"$ref": "#/$defs/planningDocumentEvidence"},
        "stale_downstream_evidence": {"$ref": "#/$defs/staleDownstreamEvidence"},
        "review_evidence": {"$ref": "#/$defs/reviewEvidence"},
        "reentry_owners": {"$ref": "#/$defs/reentryOwners"},
        "interrupted_resume_target": {
          "enum": [
            "guru-active-task-planning-review", "guru-resume-requirement-exploration",
            "guru-resume-implementation", "guru-resume-phase2-check",
            "guru-resume-spec-evaluation", "guru-resume-task-commit",
            "guru-resume-branch-review"
          ]
        }
      }
    },
    "proposalDecision": {
      "type": "object", "additionalProperties": false,
      "required": ["proposal_id", "proposal_digest", "decision", "confirmation_ref"],
      "properties": {
        "proposal_id": {"$ref": "#/$defs/identifier"},
        "proposal_digest": {"$ref": "#/$defs/sha256"},
        "decision": {"enum": ["accepted_current", "related", "followup", "new_task", "out_of_scope"]},
        "confirmation_ref": {"$ref": "#/$defs/identifier"}
      }
    },
    "userDecisionEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "proposal_digests", "confirmer", "confirmed_at", "evidence_summary"],
      "properties": {
        "status": {"const": "confirmed"},
        "proposal_digests": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}},
        "confirmer": {"$ref": "#/$defs/nonEmpty"},
        "confirmed_at": {"type": "string", "format": "date-time"},
        "evidence_summary": {"$ref": "#/$defs/nonEmpty"}
      }
    },
    "githubDecisionAuthority": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "url", "content_sha256", "updated_at"],
      "properties": {
        "kind": {"enum": ["issue_comment", "issue_body"]},
        "url": {
          "type": "string",
          "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*(?:#issuecomment-[1-9][0-9]*)?$"
        },
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "reentryOwners": {
      "type": "array", "uniqueItems": true, "minItems": 3, "maxItems": 3,
      "items": {"enum": ["guru-approve-task-plan", "guru-check-task", "guru-review-branch"]},
      "allOf": [
        {"contains": {"const": "guru-approve-task-plan"}},
        {"contains": {"const": "guru-check-task"}},
        {"contains": {"const": "guru-review-branch"}}
      ]
    },
    "fileEvidence": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "content_sha256"],
      "properties": {"path": {"$ref": "#/$defs/portablePath"}, "content_sha256": {"$ref": "#/$defs/sha256"}}
    },
    "aiGate": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "reviewed_scope", "excluded_scope", "load_bearing_conclusions", "findings", "summary"],
      "properties": {
        "status": {"enum": ["passed", "blocked"]},
        "reviewed_scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
        "excluded_scope": {"$ref": "#/$defs/stringList"},
        "load_bearing_conclusions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
        "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
        "summary": {"$ref": "#/$defs/nonEmpty"}
      }
    },
    "finding": {
      "type": "object", "additionalProperties": false,
      "required": ["finding_id", "severity", "status", "summary", "evidence_refs"],
      "properties": {
        "finding_id": {"$ref": "#/$defs/identifier"},
        "severity": {"enum": ["P0", "P1", "P2", "P3"]},
        "status": {"enum": ["open", "resolved", "out_of_scope"]},
        "summary": {"$ref": "#/$defs/nonEmpty"},
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      }
    },
    "contentIdentity": {
      "type": "object", "additionalProperties": false,
      "required": ["target_sha256", "content_sha256", "context_sha256", "scope_sha256", "action_sha256", "payload_sha256", "result_sha256"],
      "properties": {
        "target_sha256": {"$ref": "#/$defs/sha256"},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "context_sha256": {"$ref": "#/$defs/sha256"},
        "scope_sha256": {"$ref": "#/$defs/sha256"},
        "action_sha256": {"$ref": "#/$defs/sha256"},
        "payload_sha256": {"$ref": "#/$defs/sha256"},
        "result_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "consumer": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {"kind": {"enum": ["workflow", "skill", "stop"]}, "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}}
    },
    "error": {
      "type": "object", "additionalProperties": false,
      "required": ["codes", "summary"],
      "properties": {"codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/identifier"}}, "summary": {"$ref": "#/$defs/nonEmpty"}}
    }
  }
}
