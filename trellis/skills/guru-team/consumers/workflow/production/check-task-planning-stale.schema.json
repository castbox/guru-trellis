{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-production-check-task-workflow-planning-stale-input-1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exit_id",
    "task_ref",
    "planning_route",
    "proposal_refs"
  ],
  "properties": {
    "exit_id": {
      "const": "planning_stale"
    },
    "task_ref": {
      "type": "string",
      "pattern": "^\\.trellis/tasks/[A-Za-z0-9._/-]+$"
    },
    "planning_route": {
      "type": "string",
      "enum": [
        "reapprove_plan",
        "clarify_requirements"
      ]
    },
    "proposal_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
