{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/castbox/guru-trellis/schemas/upstream-ownership-1.0.json",
  "title": "Guru Team upstream ownership inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "target_trellis_cli",
    "baseline",
    "ownership_categories",
    "guru_owned_rules",
    "managed_path_claims",
    "legacy_entries"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "inventory_id": {"const": "guru-team-upstream-ownership"},
    "target_trellis_cli": {"const": "0.6.5"},
    "baseline": {"$ref": "#/$defs/baseline"},
    "ownership_categories": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "enum": [
          "upstream_owned",
          "guru_owned",
          "transitional_legacy",
          "unclassified"
        ]
      }
    },
    "guru_owned_rules": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {"$ref": "#/$defs/guruOwnedRule"}
    },
    "managed_path_claims": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/managedPathClaim"}
    },
    "legacy_entries": {
      "type": "array",
      "minItems": 43,
      "maxItems": 43,
      "items": {"$ref": "#/$defs/legacyEntry"}
    }
  },
  "$defs": {
    "safePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000-\\u001f]+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "issueNumber": {
      "type": "integer",
      "minimum": 1
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_commit",
        "overlay_root",
        "frozen_path_count",
        "sorted_path_set_sha256",
        "active_payload_aggregate_sha256",
        "path_set_digest_contract",
        "payload_digest_contract",
        "clean_init"
      ],
      "properties": {
        "base_commit": {"$ref": "#/$defs/gitCommit"},
        "overlay_root": {"const": "trellis/presets/guru-team/overlays"},
        "frozen_path_count": {"const": 43},
        "sorted_path_set_sha256": {"$ref": "#/$defs/sha256"},
        "active_payload_aggregate_sha256": {"$ref": "#/$defs/sha256"},
        "path_set_digest_contract": {"const": "sorted-relative-path-newline-v1"},
        "payload_digest_contract": {"const": "sorted-relative-path-nul-payload-nul-v1"},
        "clean_init": {"$ref": "#/$defs/cleanInit"}
      }
    },
    "cleanInit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "trellis_cli", "generated_count", "legacy_not_generated_count"],
      "properties": {
        "command": {"const": "trellis init -y -u ownership-audit --claude --codex --cursor"},
        "trellis_cli": {"const": "0.6.5"},
        "generated_count": {"const": 37},
        "legacy_not_generated_count": {"const": 6}
      }
    },
    "guruOwnedRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "match_type", "pattern", "category"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "match_type": {"enum": ["path_prefix", "path_glob", "skill_id_prefix"]},
        "pattern": {"type": "string", "minLength": 1},
        "category": {"const": "guru_owned"}
      }
    },
    "managedPathClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "category", "classification_rule", "covered_by_legacy_paths"],
      "properties": {
        "path": {"$ref": "#/$defs/safePath"},
        "category": {
          "enum": ["upstream_owned", "guru_owned", "transitional_legacy", "unclassified"]
        },
        "classification_rule": {"type": "string", "minLength": 1},
        "covered_by_legacy_paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/safePath"}
        }
      }
    },
    "legacyEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "category",
        "migration_state",
        "baseline_sha256",
        "generated_in_clean_init",
        "upstream_producer",
        "current_guru_behavior",
        "replacement_owners",
        "blocking_issues",
        "removal_issue",
        "update_upgrade_conflict",
        "dogfood_status",
        "target_business_repo_status"
      ],
      "properties": {
        "path": {"$ref": "#/$defs/safePath"},
        "category": {"enum": ["transitional_legacy", "upstream_owned", "unclassified"]},
        "migration_state": {"enum": ["active", "removed"]},
        "baseline_sha256": {"$ref": "#/$defs/sha256"},
        "generated_in_clean_init": {"type": "boolean"},
        "upstream_producer": {"type": "string", "minLength": 1},
        "current_guru_behavior": {"type": "string", "minLength": 1},
        "replacement_owners": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^guru-[a-z0-9]+(?:-[a-z0-9]+)*$"}
        },
        "blocking_issues": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/issueNumber"}
        },
        "removal_issue": {"$ref": "#/$defs/issueNumber"},
        "update_upgrade_conflict": {"type": "string", "minLength": 1},
        "dogfood_status": {
          "enum": ["canonical_payload_matches_installed_copy", "removed_with_audit_history"]
        },
        "target_business_repo_status": {
          "enum": ["installed_when_selected_platform_applies", "no_longer_installed"]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"migration_state": {"const": "active"}}, "required": ["migration_state"]},
          "then": {
            "properties": {
              "category": {"const": "transitional_legacy"},
              "dogfood_status": {"const": "canonical_payload_matches_installed_copy"},
              "target_business_repo_status": {"const": "installed_when_selected_platform_applies"}
            }
          }
        },
        {
          "if": {"properties": {"migration_state": {"const": "removed"}}, "required": ["migration_state"]},
          "then": {
            "properties": {
              "category": {"const": "upstream_owned"},
              "dogfood_status": {"const": "removed_with_audit_history"},
              "target_business_repo_status": {"const": "no_longer_installed"}
            }
          }
        }
      ]
    }
  }
}
