{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/castbox/guru-trellis/trellis/workflows/guru-team/schemas/closeout-plan.schema.json",
  "title": "Guru Team closeout plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task", "git", "inputs", "review", "publish", "marketplace", "projection", "transitions", "plan_digest"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "source_issue", "active_locator", "archive_locator"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "source_issue": {"type": "integer", "minimum": 1},
        "active_locator": {"$ref": "#/$defs/taskPath"},
        "archive_locator": {"$ref": "#/$defs/archivePath"}
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "remote", "base_branch", "head_branch", "reviewed_work_head"],
      "properties": {
        "repo": {"type": "string", "pattern": "^[^/\\s]+/[^/\\s]+$"},
        "remote": {"type": "string", "minLength": 1},
        "base_branch": {"type": "string", "minLength": 1},
        "head_branch": {"type": "string", "minLength": 1},
        "reviewed_work_head": {"$ref": "#/$defs/sha40"}
      }
    },
    "inputs": {
      "type": "object",
      "minProperties": 6,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"$ref": "#/$defs/safePath"},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_locator", "reviewed_head", "changed_paths", "close_issues_reviewed"],
      "properties": {
        "gate_locator": {"$ref": "#/$defs/taskPath"},
        "reviewed_head": {"$ref": "#/$defs/sha40"},
        "changed_paths": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/safePath"}},
        "close_issues_reviewed": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1}}
      }
    },
    "publish": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body_sha256", "draft", "draft_to_ready", "match"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "body_sha256": {"$ref": "#/$defs/sha256"},
        "draft": {"const": true},
        "draft_to_ready": {"const": true},
        "match": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repo", "head", "base"],
          "properties": {
            "repo": {"type": "string", "minLength": 3},
            "head": {"type": "string", "minLength": 1},
            "base": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "marketplace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "pending_machine", "verifier_artifact_locator"],
      "properties": {
        "required": {"type": "boolean"},
        "pending_machine": {"type": "object"},
        "verifier_artifact_locator": {"const": "marketplace-verification.json"}
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active_locator", "archive_locator", "finish_summary_locator", "metadata_allowlist", "move_paths", "tracked_move_paths", "untracked_archive_outputs", "evidence_paths", "summary_placeholder", "summary_template_sha256", "summary_template", "runtime_fact_fields"],
      "properties": {
        "active_locator": {"$ref": "#/$defs/taskPath"},
        "archive_locator": {"$ref": "#/$defs/archivePath"},
        "finish_summary_locator": {"$ref": "#/$defs/archivePath"},
        "metadata_allowlist": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/safePath"}
        },
        "move_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/safePath"}
        },
        "tracked_move_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/safePath"}
        },
        "untracked_archive_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "contains": {"const": "finish-summary.json"},
          "items": {"$ref": "#/$defs/safePath"}
        },
        "evidence_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/taskPath"}
        },
        "summary_placeholder": {
          "type": "object",
          "additionalProperties": false,
          "required": ["number", "url", "ref"],
          "properties": {
            "number": {"const": 9223372036854775807},
            "url": {"type": "string", "pattern": "^https://github\\.com/[^/]+/[^/]+/pull/9223372036854775807$"},
            "ref": {"const": "PR #9223372036854775807"}
          }
        },
        "summary_template_sha256": {"$ref": "#/$defs/sha256"},
        "summary_template": {"type": "object"},
        "runtime_fact_fields": {
          "const": ["github.pr_url", "index.search_terms.pr_refs"]
        }
      }
    },
    "transitions": {
      "const": ["prepared", "content_pushed", "evidence_pushed", "draft_bound", "projection_validated", "archive_moved", "archive_pushed", "ready"]
    },
    "plan_digest": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha40": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "safePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!\\.trellis/(?:workspace|\\.runtime)/).+$"
    },
    "taskPath": {
      "allOf": [
        {"$ref": "#/$defs/safePath"},
        {"pattern": "^\\.trellis/tasks/"}
      ]
    },
    "archivePath": {
      "allOf": [
        {"$ref": "#/$defs/safePath"},
        {"pattern": "^\\.trellis/tasks/archive/[0-9]{4}-[0-9]{2}/"}
      ]
    }
  }
}
