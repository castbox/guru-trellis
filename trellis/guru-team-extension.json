      "review.md",
      "pr-body.md",
      "review-gate.json",
      "pr-readiness.json",
      "closeout-plan.json",
      "marketplace-verification.json",
      "finish-summary.json"
    ],
    "skill_contracts": {
      "canonical_root": "trellis/skills/guru-team/",
      "installed_root": ".trellis/guru-team/skills/",
      "registry_schema_id": "guru-team-skill-registry-1.0",
      "interface_schema_id": "guru-team-skill-interface-1.0",
