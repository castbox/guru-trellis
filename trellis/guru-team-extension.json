      "active_skill_ids": ["guru-create-task-commit"],
      "reserved_skill_ids": ["guru-create-work-commit"],
      "registry_lifecycle": ["reserved", "active"],
      "workflow_markers": ["guru-skill-invoke", "guru-skill-exit"]
    },
    "companion_scripts": [
      "check-env",
      "version",
      "prepare-task",
      "check-workspace-boundary",
      "check-skill-packages",
      "resolve-human-artifacts",
      "record-planning-approval",
      "check-planning-approval",
      "record-phase2-check",
      "check-phase2-check",
      "record-agent-assignment",
      "record-subagent-liveness-event",
      "check-subagent-liveness",
      "check-agent-assignment",
      "check-commit-messages",
      "create-task-commit",
      "format-merge-commit",
      "review-branch",
      "check-review-gate",
      "verify-marketplace",
      "finish-work",
      "backfill-finish-summary",
      "publish-pr"
    ]
