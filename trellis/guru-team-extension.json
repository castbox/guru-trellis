    "trellis_cli": [
      "0.6.5"
    ]
  },
  "public_api": {
    "workflow_template_id": "guru-team",
    "workflow_marketplace": "gh:castbox/guru-trellis/trellis",
    "managed_paths": [
      ".trellis/guru-team/",
      ".trellis/guru-team/skills/",
      ".agents/skills/guru-*/",
      ".codex/skills/guru-*/",
      ".cursor/skills/guru-*/",
      ".claude/skills/guru-*/",
      ".agents/skills/trellis-start/",
      ".agents/skills/trellis-continue/",
      ".agents/skills/trellis-finish-work/",
      ".codex/prompts/",
      ".codex/skills/",
      ".cursor/commands/",
      ".claude/commands/trellis/"
    ],
    "config_files": [
      ".trellis/guru-team/config.yml",
      ".trellis/config.yaml"
    ],
    "artifact_contracts": [
      "task-start-context.json",
      ".trellis/guru-team/extension.json",
      "planning-approval.json",
      "phase2-check.json",
      "task-commit-plans/*.json",
      "agent-assignment.json",
      "issue-scope-ledger.json",
