{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/castbox/guru-trellis/main/trellis/workflows/guru-team/schemas/intake-handoff.schema.json",
  "title": "Guru Team Trellis Intake Handoff",
  "type": "object",
  "required": [
    "schema_version",
    "source_issue",
    "slug",
    "task_slug",
    "branch_name",
    "workspace_mode",
    "workspace_path",
    "base_branch",
    "create_task_command",
    "preflight"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "source_issue": {
      "type": ["object", "null"],
      "description": "Confirmed GitHub issue used as intake provenance. Null means prepare only produced proposed_issue and still requires AI/human confirmation before GitHub writes or task creation.",
      "required": ["number", "url", "created_by_workflow"],
      "properties": {
        "number": {
          "type": "integer"
        },
        "url": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "created_by_workflow": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "proposed_issue": {
      "type": ["object", "null"],
      "description": "Side-effect-free proposed GitHub issue title/body for freeform intake when no source issue has been confirmed.",
      "properties": {
        "repo": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "body_reviewed": {
          "type": "boolean"
        },
        "create_issue_command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "requires_confirmation": {
      "type": ["object", "null"],
      "description": "Explicit confirmation required before side effects such as GitHub issue creation, worktree creation, branch creation, or Trellis task creation.",
      "additionalProperties": true
    },
    "handoff_path": {
      "type": "string",
      "description": "Resolved handoff path for the planned or chosen workspace. Default prepare output reports this path but does not write it until an explicit workspace executor runs."
    },
    "handoff_written": {
      "type": "boolean",
      "description": "True only when prepare wrote the handoff artifact after --create-worktree or --create-task was explicitly requested."
    },
    "slug": {
      "type": "string"
    },
    "task_slug": {
      "type": "string"
    },
    "task_title": {
      "type": "string"
    },
    "branch_name": {
      "type": "string"
    },
    "workspace_mode": {
      "enum": ["worktree", "current"]
    },
    "workspace_path": {
      "type": "string"
    },
    "base_branch": {
      "type": "string"
    },
    "create_task_command": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_dir": {
      "type": ["string", "null"]
    },
    "issue_scope_ledger": {
      "type": "object",
      "description": "Default seed for the task-level Issue Scope Ledger. source_issue remains intake provenance and is not the final close scope.",
      "properties": {
        "primary_issue": {
          "$ref": "#/$defs/issue_scope_entry"
        },
        "close_issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/issue_scope_entry"
          }
        },
        "related_issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/issue_scope_entry"
          }
        },
        "followup_issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/issue_scope_entry"
          }
        }
      },
      "additionalProperties": true
    },
    "duplicate_search": {
      "type": "object",
      "additionalProperties": true
    },
    "preflight": {
      "type": "object",
      "required": ["repo_root", "current_branch", "current_checkout", "dirty", "worktree_root", "existing_worktrees"],
      "properties": {
        "repo_root": {
          "type": "string"
        },
        "current_branch": {
          "type": "string"
        },
        "current_checkout": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        },
        "worktree_root": {
          "type": "string"
        },
        "existing_worktrees": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "base_freshness": {
          "type": "object",
          "description": "Freshness evidence for the selected base branch. Executor paths fetch the remote base, record local/remote heads, and fail closed on stale or divergent bases.",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "issue_scope_entry": {
      "type": "object",
      "required": ["number"],
      "properties": {
        "number": {
          "type": "integer"
        },
        "url": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "acceptance_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
