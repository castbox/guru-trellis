{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://castbox.github.io/guru-trellis/schemas/marketplace-verification.schema.json",
  "title": "Guru Team Remote Marketplace Verification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "status", "repo", "remote", "branch", "marketplace_source", "verified_head", "remote_head", "task_dir", "steps", "assets"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "generated_at": {"type": "string", "minLength": 1},
    "status": {"enum": ["passed", "failed"]},
    "repo": {"type": "string", "minLength": 1},
    "remote": {"type": "string", "minLength": 1},
    "branch": {"type": "string", "minLength": 1},
    "marketplace_source": {"type": "string", "minLength": 1},
    "verified_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "remote_head": {"type": "string", "pattern": "^([0-9a-f]{40})?$"},
    "task_dir": {"type": "string", "pattern": "^\\.trellis/tasks/"},
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "exit_code", "stdout_sha256", "stderr_sha256", "stdout_size_bytes", "stderr_size_bytes", "passed"],
        "properties": {
          "command": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "exit_code": {"type": "integer"},
          "stdout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "stderr_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "stdout_size_bytes": {"type": "integer", "minimum": 0},
          "stderr_size_bytes": {"type": "integer", "minimum": 0},
          "passed": {"type": "boolean"}
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_sha256", "preview_sha256", "task_start_context_schema_sha256", "finish_summary_schema_sha256", "runtime_gitignore_present", "workspace_gitignore_present", "session_auto_commit_false", "legacy_handoff_absent", "legacy_intake_schema_absent"],
      "properties": {
        "workflow_sha256": {"type": "string", "pattern": "^([0-9a-f]{64})?$"},
        "preview_sha256": {"type": "string", "pattern": "^([0-9a-f]{64})?$"},
        "task_start_context_schema_sha256": {"type": "string", "pattern": "^([0-9a-f]{64})?$"},
        "finish_summary_schema_sha256": {"type": "string", "pattern": "^([0-9a-f]{64})?$"},
        "runtime_gitignore_present": {"type": "boolean"},
        "workspace_gitignore_present": {"type": "boolean"},
        "session_auto_commit_false": {"type": "boolean"},
        "legacy_handoff_absent": {"type": "boolean"},
        "legacy_intake_schema_absent": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "passed"}}},
      "then": {
        "properties": {
          "remote_head": {"pattern": "^[0-9a-f]{40}$"},
          "assets": {
            "properties": {
              "workflow_sha256": {"pattern": "^[0-9a-f]{64}$"},
              "preview_sha256": {"pattern": "^[0-9a-f]{64}$"},
              "task_start_context_schema_sha256": {"pattern": "^[0-9a-f]{64}$"},
              "finish_summary_schema_sha256": {"pattern": "^[0-9a-f]{64}$"},
              "runtime_gitignore_present": {"const": true},
              "workspace_gitignore_present": {"const": true},
              "session_auto_commit_false": {"const": true},
              "legacy_handoff_absent": {"const": true},
              "legacy_intake_schema_absent": {"const": true}
            }
          }
        }
      }
    }
  ]
}
