{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://castbox.github.io/guru-trellis/schemas/marketplace-verification.schema.json",
  "title": "Guru Team Remote Marketplace Verification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "status", "repo", "remote", "branch", "marketplace_source", "verified_head", "remote_head", "task_dir", "steps", "assets"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "generated_at": {"type": "string"},
    "status": {"enum": ["passed", "failed"]},
    "repo": {"type": "string"},
    "remote": {"type": "string"},
    "branch": {"type": "string"},
    "marketplace_source": {"type": "string"},
    "verified_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "remote_head": {"type": "string", "pattern": "^([0-9a-f]{40})?$"},
    "task_dir": {"type": "string", "pattern": "^\\.trellis/tasks/"},
    "steps": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "assets": {"type": "object", "required": ["workflow_sha256", "preview_sha256", "task_start_context_schema_sha256", "runtime_gitignore_present", "legacy_handoff_absent", "legacy_intake_schema_absent"], "additionalProperties": false, "properties": {"workflow_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "preview_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "task_start_context_schema_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "runtime_gitignore_present": {"const": true}, "legacy_handoff_absent": {"const": true}, "legacy_intake_schema_absent": {"const": true}}}
  }
}
