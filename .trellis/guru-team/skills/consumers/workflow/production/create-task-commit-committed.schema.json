{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-production-create-task-commit-workflow-committed-input-1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_ref",
    "base_ref",
    "committed_head"
  ],
  "properties": {
    "task_ref": {
      "type": "string",
      "pattern": "^\\.trellis/tasks/[A-Za-z0-9._/-]+$"
    },
    "base_ref": {
      "type": "string",
      "minLength": 1
    },
    "committed_head": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    }
  }
}
