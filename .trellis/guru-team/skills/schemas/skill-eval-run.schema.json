{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "guru-team-skill-eval-run-1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "skill_id", "interface_schema_id", "corpus_schema_id", "corpus_version", "adapter", "platform", "status", "cases", "evidence_path"],
  "properties": {
    "schema_version": {"const": "1.0"}, "skill_id": {"type": "string", "minLength": 1}, "interface_schema_id": {"const": "guru-team-skill-interface-1.3"}, "corpus_schema_id": {"const": "guru-team-skill-evals-1.0"}, "corpus_version": {"const": "1.0"}, "adapter": {"enum": ["shared", "codex", "claude", "cursor"]}, "platform": {"enum": ["shared", "codex", "claude", "cursor"]}, "status": {"enum": ["passed", "evaluation_failed", "execution_error", "unsupported"]}, "cases": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/case"}}, "evidence_path": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "assertionResult": {"type": "object", "additionalProperties": false, "required": ["id", "passed", "detail"], "properties": {"id": {"type": "string", "minLength": 1}, "passed": {"type": "boolean"}, "detail": {"type": "string", "minLength": 1}}},
    "case": {"type": "object", "additionalProperties": false, "required": ["case_id", "comparison_side", "status", "deterministic_results", "semantic_results", "transcript_locator", "timing_ms", "feedback"], "properties": {"case_id": {"type": "string", "minLength": 1}, "comparison_side": {"enum": ["current", "comparison"]}, "status": {"enum": ["passed", "evaluation_failed", "execution_error", "unsupported"]}, "actual_exit": {"type": "string", "minLength": 1}, "deterministic_results": {"type": "array", "items": {"$ref": "#/$defs/assertionResult"}}, "semantic_results": {"type": "array", "items": {"$ref": "#/$defs/assertionResult"}}, "transcript_locator": {"type": "string", "minLength": 1}, "timing_ms": {"type": "integer", "minimum": 0}, "feedback": {"type": "array", "items": {"type": "string", "minLength": 1}}}}
  }
}
