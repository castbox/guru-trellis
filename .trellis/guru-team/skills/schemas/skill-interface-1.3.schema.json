{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/castbox/guru-trellis/schemas/guru-team-skill-interface-1.3.json",
  "title": "Guru Team minimal typed handoff workflow skill interface",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "id", "name", "description", "state", "judgment_mode", "modes", "entry_preconditions", "runtime_dependency", "ordered_stages", "artifacts", "schemas", "validators", "external_exits", "reentry", "tests", "platform_destinations", "public_contracts"],
  "properties": {
    "$schema": {"const": "../../schemas/skill-interface-1.3.schema.json"},
    "schema_version": {"const": "1.3"},
    "id": {"$ref": "#/$defs/skillId"},
    "name": {"$ref": "#/$defs/skillId"},
    "description": {"type": "string", "minLength": 1},
    "state": {"const": "active"},
    "judgment_mode": {"enum": ["semantic", "deterministic"]},
    "modes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow", "standalone"],
      "properties": {
        "workflow": {"$ref": "#/$defs/workflowMode"},
        "standalone": {"$ref": "#/$defs/standaloneMode"}
      }
    },
    "entry_preconditions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/precondition"}},
    "runtime_dependency": {"$ref": "#/$defs/runtimeDependency"},
    "ordered_stages": {"type": "array", "items": {"type": "string"}},
    "artifacts": {"type": "array", "items": {"$ref": "#/$defs/pathItem"}},
    "schemas": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/pathItem"}},
    "validators": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/validator"}},
    "external_exits": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/exit"}},
    "reentry": {"$ref": "#/$defs/reentry"},
    "tests": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$))tests/.+$"}},
    "platform_destinations": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["shared", "codex", "cursor", "claude"]}},
    "public_contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "invocation", "outputs", "consumer_inputs", "projections", "private_artifacts"],
      "properties": {
        "input": {"oneOf": [{"$ref": "#/$defs/structuredInput"}, {"$ref": "#/$defs/scalarInput"}]},
        "invocation": {"$ref": "#/$defs/invocation"},
        "outputs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/output"}},
        "consumer_inputs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/consumerInput"}},
        "projections": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/projection"}},
        "private_artifacts": {"type": "array", "items": {"$ref": "#/$defs/privateArtifact"}}
      }
    }
  },
  "allOf": [
    {"if": {"properties": {"judgment_mode": {"const": "semantic"}}, "required": ["judgment_mode"]}, "then": {"properties": {"ordered_stages": {"const": ["forward_behavior", "ai_review_gate", "conditional_human_confirmation", "recorder_validator", "typed_exit"]}}}},
    {"if": {"properties": {"judgment_mode": {"const": "deterministic"}}, "required": ["judgment_mode"]}, "then": {"properties": {"ordered_stages": {"const": ["forward_behavior", "recorder_validator", "typed_exit"]}}}}
  ],
  "$defs": {
    "skillId": {"type": "string", "pattern": "^guru-[a-z0-9]+(?:-[a-z0-9]+)+$"},
    "localId": {"type": "string", "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"},
    "safePath": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "workflowMode": {"type": "object", "additionalProperties": false, "required": ["routing", "entry_precondition_ids"], "properties": {"routing": {"const": "global_workflow"}, "entry_precondition_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}}}},
    "standaloneMode": {"type": "object", "additionalProperties": false, "required": ["routing", "entry_precondition_ids"], "properties": {"routing": {"const": "direct_discovery"}, "entry_precondition_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}}}},
    "runtimeDependency": {"type": "object", "additionalProperties": false, "required": ["extension_id", "api_version", "manifest_path", "dispatcher", "distribution", "package_portability"], "properties": {"extension_id": {"const": "guru-team"}, "api_version": {"const": "1.0"}, "manifest_path": {"const": ".trellis/guru-team/extension.json"}, "dispatcher": {"const": "run-skill-command"}, "distribution": {"const": "guru-team-preset"}, "package_portability": {"const": "not-self-contained"}}},
    "precondition": {"type": "object", "additionalProperties": false, "required": ["id", "evidence", "binding", "freshness"], "properties": {"id": {"type": "string", "pattern": "^[a-z0-9_]+$"}, "evidence": {"type": "string", "minLength": 1}, "binding": {"type": "string", "minLength": 1}, "freshness": {"type": "string", "minLength": 1}}},
    "pathItem": {"type": "object", "additionalProperties": false, "required": ["id", "path"], "properties": {"id": {"type": "string", "pattern": "^[a-z0-9_]+$"}, "path": {"$ref": "#/$defs/safePath"}}},
    "validator": {"type": "object", "additionalProperties": false, "required": ["id", "command", "runtime_command", "objective_scope"], "properties": {"id": {"type": "string", "pattern": "^[a-z0-9_]+$"}, "command": {"$ref": "#/$defs/safePath"}, "runtime_command": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "objective_scope": {"type": "string", "minLength": 1}}},
    "exit": {"type": "object", "additionalProperties": false, "required": ["id", "evidence", "consumer"], "properties": {"id": {"$ref": "#/$defs/localId"}, "evidence": {"type": "string", "minLength": 1}, "consumer": {"$ref": "#/$defs/consumerIdentity"}}},
    "consumerIdentity": {"type": "object", "additionalProperties": false, "required": ["kind", "id"], "properties": {"kind": {"enum": ["workflow", "skill", "stop"]}, "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}}},
    "reentry": {"type": "object", "additionalProperties": false, "required": ["identity", "freshness", "stale_behavior"], "properties": {"identity": {"type": "string", "minLength": 1}, "freshness": {"type": "string", "minLength": 1}, "stale_behavior": {"const": "fail_closed"}}},
    "schemaRef": {"type": "object", "additionalProperties": false, "required": ["schema_id", "path"], "properties": {"schema_id": {"type": "string", "minLength": 1}, "path": {"$ref": "#/$defs/safePath"}}},
    "exampleRef": {"type": "object", "additionalProperties": false, "required": ["id", "path"], "properties": {"id": {"$ref": "#/$defs/localId"}, "path": {"$ref": "#/$defs/safePath"}}},
    "structuredInput": {"type": "object", "additionalProperties": false, "required": ["kind", "aggregate_schema", "profiles"], "properties": {"kind": {"const": "structured_json"}, "aggregate_schema": {"$ref": "#/$defs/schemaRef"}, "profiles": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/inputProfile"}}}},
    "inputProfile": {"type": "object", "additionalProperties": false, "required": ["id", "schema", "example", "discriminator"], "properties": {"id": {"$ref": "#/$defs/localId"}, "schema": {"$ref": "#/$defs/schemaRef"}, "example": {"$ref": "#/$defs/exampleRef"}, "discriminator": {"type": "object", "additionalProperties": false, "required": ["field", "value"], "properties": {"field": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}, "value": {"type": "string", "minLength": 1}}}}},
    "scalarInput": {"type": "object", "additionalProperties": false, "required": ["kind", "arguments", "example_argv"], "properties": {"kind": {"const": "scalar_cli"}, "arguments": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/scalarArgument"}}, "example_argv": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}},
    "scalarArgument": {"type": "object", "additionalProperties": false, "required": ["id", "flag", "type", "required"], "properties": {"id": {"$ref": "#/$defs/localId"}, "flag": {"type": "string", "pattern": "^--[a-z][a-z0-9-]*$"}, "type": {"enum": ["string", "positive_integer", "ascii_enum"]}, "required": {"type": "boolean"}}},
    "invocation": {"type": "object", "additionalProperties": false, "required": ["command_id", "wrapper", "input_binding", "stdout_contract", "error_schema", "error_example", "example_argv"], "properties": {"command_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "wrapper": {"$ref": "#/$defs/safePath"}, "input_binding": {"oneOf": [{"type": "object", "additionalProperties": false, "required": ["kind", "profile_id"], "properties": {"kind": {"const": "structured_json"}, "profile_id": {"$ref": "#/$defs/localId"}}}, {"type": "object", "additionalProperties": false, "required": ["kind", "argument_ids"], "properties": {"kind": {"const": "scalar_cli"}, "argument_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/localId"}}}}]}, "stdout_contract": {"const": "single_typed_exit"}, "error_schema": {"$ref": "#/$defs/schemaRef"}, "error_example": {"$ref": "#/$defs/exampleRef"}, "example_argv": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}},
    "output": {"type": "object", "additionalProperties": false, "required": ["exit_id", "schema", "example", "consumer_use_ids"], "properties": {"exit_id": {"$ref": "#/$defs/localId"}, "schema": {"$ref": "#/$defs/schemaRef"}, "example": {"$ref": "#/$defs/exampleRef"}, "consumer_use_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/localId"}}}},
    "consumerInput": {"oneOf": [{"$ref": "#/$defs/workflowConsumerInput"}, {"$ref": "#/$defs/skillConsumerInput"}, {"$ref": "#/$defs/stopConsumerInput"}, {"$ref": "#/$defs/zeroStopConsumerInput"}]},
    "workflowConsumerInput": {"type": "object", "additionalProperties": false, "required": ["id", "consumer", "payload_kind", "contract"], "properties": {"id": {"$ref": "#/$defs/localId"}, "consumer": {"type": "object", "additionalProperties": false, "required": ["kind", "id"], "properties": {"kind": {"const": "workflow"}, "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}}}, "payload_kind": {"const": "structured_json"}, "contract": {"type": "object", "additionalProperties": false, "required": ["kind", "schema_id", "path"], "properties": {"kind": {"const": "json_schema"}, "schema_id": {"type": "string", "minLength": 1}, "path": {"type": "string", "pattern": "^consumers/workflow/(?!(?:[^/\\\\]+/)*\\.{1,2}(?:/|$))(?!.*//)[^/\\\\]+(?:/[^/\\\\]+)*$"}}}}},
    "skillConsumerInput": {"type": "object", "additionalProperties": false, "required": ["id", "consumer", "payload_kind", "contract"], "properties": {"id": {"$ref": "#/$defs/localId"}, "consumer": {"type": "object", "additionalProperties": false, "required": ["kind", "id"], "properties": {"kind": {"const": "skill"}, "id": {"$ref": "#/$defs/skillId"}}}, "payload_kind": {"const": "structured_json"}, "contract": {"oneOf": [{"type": "object", "additionalProperties": false, "required": ["kind", "interface_path", "input_kind", "profile_id"], "properties": {"kind": {"const": "skill_input"}, "interface_path": {"$ref": "#/$defs/safePath"}, "input_kind": {"const": "structured_json"}, "profile_id": {"$ref": "#/$defs/localId"}}}, {"type": "object", "additionalProperties": false, "required": ["kind", "interface_path", "input_kind"], "properties": {"kind": {"const": "skill_input"}, "interface_path": {"$ref": "#/$defs/safePath"}, "input_kind": {"const": "scalar_cli"}}}]}}},
    "stopConsumerInput": {"type": "object", "additionalProperties": false, "required": ["id", "consumer", "payload_kind", "contract"], "properties": {"id": {"$ref": "#/$defs/localId"}, "consumer": {"type": "object", "additionalProperties": false, "required": ["kind", "id"], "properties": {"kind": {"const": "stop"}, "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}}}, "payload_kind": {"const": "structured_json"}, "contract": {"type": "object", "additionalProperties": false, "required": ["kind", "schema_id", "path"], "properties": {"kind": {"const": "json_schema"}, "schema_id": {"type": "string", "minLength": 1}, "path": {"type": "string", "pattern": "^consumers/stop/(?!(?:[^/\\\\]+/)*\\.{1,2}(?:/|$))(?!.*//)[^/\\\\]+(?:/[^/\\\\]+)*$"}}}}},
    "zeroStopConsumerInput": {"type": "object", "additionalProperties": false, "required": ["id", "consumer", "payload_kind"], "properties": {"id": {"$ref": "#/$defs/localId"}, "consumer": {"type": "object", "additionalProperties": false, "required": ["kind", "id"], "properties": {"kind": {"const": "stop"}, "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}}}, "payload_kind": {"const": "zero_payload"}}},
    "projection": {"oneOf": [{"$ref": "#/$defs/directProjection"}, {"$ref": "#/$defs/selectProjection"}, {"$ref": "#/$defs/renameProjection"}, {"$ref": "#/$defs/normalizeProjection"}]},
    "directProjection": {"type": "object", "additionalProperties": false, "required": ["id", "exit_id", "consumer_input_id", "operation"], "properties": {"id": {"$ref": "#/$defs/localId"}, "exit_id": {"$ref": "#/$defs/localId"}, "consumer_input_id": {"$ref": "#/$defs/localId"}, "operation": {"const": "direct"}}},
    "selectProjection": {"type": "object", "additionalProperties": false, "required": ["id", "exit_id", "consumer_input_id", "operation", "mappings"], "properties": {"id": {"$ref": "#/$defs/localId"}, "exit_id": {"$ref": "#/$defs/localId"}, "consumer_input_id": {"$ref": "#/$defs/localId"}, "operation": {"const": "select"}, "mappings": {"type": "array", "items": {"$ref": "#/$defs/fieldMapping"}}}},
    "renameProjection": {"type": "object", "additionalProperties": false, "required": ["id", "exit_id", "consumer_input_id", "operation", "mappings"], "properties": {"id": {"$ref": "#/$defs/localId"}, "exit_id": {"$ref": "#/$defs/localId"}, "consumer_input_id": {"$ref": "#/$defs/localId"}, "operation": {"const": "rename"}, "mappings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/fieldMapping"}}}},
    "normalizeProjection": {"type": "object", "additionalProperties": false, "required": ["id", "exit_id", "consumer_input_id", "operation", "mappings"], "properties": {"id": {"$ref": "#/$defs/localId"}, "exit_id": {"$ref": "#/$defs/localId"}, "consumer_input_id": {"$ref": "#/$defs/localId"}, "operation": {"const": "normalize"}, "mappings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/normalizeMapping"}}}},
    "fieldMapping": {"type": "object", "additionalProperties": false, "required": ["source", "target"], "properties": {"source": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}, "target": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}}},
    "normalizeMapping": {"type": "object", "additionalProperties": false, "required": ["source", "target", "normalizer"], "properties": {"source": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}, "target": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}, "normalizer": {"enum": ["trim_ascii_outer_whitespace", "lowercase_ascii_enum", "positive_integer_canonicalization"]}}},
    "privateArtifact": {"type": "object", "additionalProperties": false, "required": ["id", "kind", "schema", "persistence"], "properties": {"id": {"$ref": "#/$defs/localId"}, "kind": {"enum": ["runtime_checkpoint", "gate_evidence"]}, "schema": {"$ref": "#/$defs/schemaRef"}, "persistence": {"enum": ["stdout_only_pre_task", "task_local_tracked", "ignored_runtime"]}}}
  }
}
