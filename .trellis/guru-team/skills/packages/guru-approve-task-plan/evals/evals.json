  "skill_name": "guru-approve-task-plan",
  "evals": [
    {
      "id": "approved-initial",
      "prompt": "Complete the initial_review semantic owner round and invoke guru-approve-task-plan through its public wrapper; return the checker-derived approved route.",
      "expected_exit": "approved",
      "expected_output": "The public DTO is the declared approved route.",
      "input_profile_id": "initial_review",
      "assertions": {
        "deterministic": [
          {
            "id": "expected-route",
            "kind": "json_path",
            "pointer": "/exit_id",
            "operation": "equals",
            "expected": "approved"
          },
          {
            "id": "public-only",
            "kind": "trace",
            "invariant": "public_invocation_only"
          },
          {
            "id": "evals-not-loaded",
            "kind": "trace",
            "invariant": "evals_not_loaded_by_skill"
          },
          {
            "id": "private-runtime-not-read",
            "kind": "trace",
            "invariant": "private_runtime_not_read_by_agent"
          }
        ]
      },
      "files": ["evals/files/approved-initial-input.json", "evals/files/approved-initial-facts.json"]
    },
