{
  "$schema": "../../schemas/skill-interface-1.3.schema.json",
  "schema_version": "1.3",
  "id": "guru-review-branch",
  "name": "guru-review-branch",
  "description": "Review a committed task branch through independent review, qualification-first findings, closure, fresh final review, and four typed exits.",
  "state": "active",
  "judgment_mode": "semantic",
  "modes": {
    "workflow": {
      "routing": "global_workflow",
      "entry_precondition_ids": [
        "runtime_dependency",
        "workspace_boundary",
        "task_identity",
        "commit_handoff",
        "planning_approval",
        "phase2_check",
        "issue_scope_ledger",
        "docs_ssot_outcome",
        "review_range",
        "working_tree",
        "reviewer_assignment",
        "review_evidence",
        "invocation_freshness"
      ]
    },
    "standalone": {
      "routing": "direct_discovery",
      "entry_precondition_ids": [
        "runtime_dependency",
        "workspace_boundary",
        "task_identity",
        "commit_handoff",
        "planning_approval",
        "phase2_check",
        "issue_scope_ledger",
        "docs_ssot_outcome",
        "review_range",
        "working_tree",
        "reviewer_assignment",
        "review_evidence",
        "invocation_freshness"
      ]
    }
  },
  "entry_preconditions": [
    {"id": "runtime_dependency", "evidence": "installed extension, dispatcher, active package, schemas and review commands", "binding": "complete compatible Guru Team preset", "freshness": "validated before each command"},
    {"id": "workspace_boundary", "evidence": "task-local context and worktree mapping", "binding": "actual root equals expected task worktree", "freshness": "rebuilt before record and check"},
    {"id": "task_identity", "evidence": "task.json and active locator", "binding": "task, branch and in_progress status", "freshness": "current task reread"},
    {"id": "commit_handoff", "evidence": "guru-create-task-commit committed DTO and task commit plan", "binding": "task, base and committed HEAD", "freshness": "HEAD and commit evidence current"},
    {"id": "planning_approval", "evidence": "checker-passed planning-approval.json", "binding": "exact approved planning documents", "freshness": "planning checker rerun"},
    {"id": "phase2_check", "evidence": "checker-passed phase2-check.json", "binding": "complete implementation scope and post-commit metadata audit", "freshness": "Phase 2 checker rerun"},
    {"id": "issue_scope_ledger", "evidence": "current issue-scope-ledger.json", "binding": "primary, close, related and follow-up scope", "freshness": "current semantic projection"},
    {"id": "docs_ssot_outcome", "evidence": "approved Docs SSOT Plan and implementation handoff", "binding": "durable docs reconciliation", "freshness": "reviewed against current diff"},
    {"id": "review_range", "evidence": "origin base, committed HEAD and complete diff", "binding": "origin/<base>...<head>", "freshness": "rebuilt for every round"},
    {"id": "working_tree", "evidence": "complete status snapshot", "binding": "clean or owner-declared review metadata only", "freshness": "checked before record and check"},
    {"id": "reviewer_assignment", "evidence": "agent-assignment.json and liveness/recovery chain", "binding": "independent finding, closure and fresh final roles", "freshness": "assignment checker rerun"},
    {"id": "review_evidence", "evidence": "reviews/*.md, review.md and report digests", "binding": "ordered current-head lifecycle", "freshness": "raw reports reread"},
    {"id": "invocation_freshness", "evidence": "public input, AI Gate, artifact and actual exit", "binding": "one complete owner invocation", "freshness": "checker rejects drift or ambiguity"}
  ],
  "runtime_dependency": {
    "extension_id": "guru-team",
    "api_version": "1.0",
    "manifest_path": ".trellis/guru-team/extension.json",
    "dispatcher": "run-skill-command",
    "distribution": "guru-team-preset",
    "package_portability": "not-self-contained"
  },
  "ordered_stages": [
    "forward_behavior",
    "ai_review_gate",
    "conditional_human_confirmation",
    "recorder_validator",
    "typed_exit"
  ],
  "artifacts": [
    {"id": "review_gate_example", "path": "examples/review-gate.json"},
    {"id": "public_input_example", "path": "examples/public-branch-review-input.json"},
    {"id": "public_input_authoring_example", "path": "examples/public-branch-review-authoring.json"},
    {"id": "public_invocation_error_example", "path": "examples/public-invocation-error.json"},
    {"id": "public_output_passed_example", "path": "examples/public-passed-output.json"},
    {"id": "public_output_implementation_required_example", "path": "examples/public-implementation-required-output.json"},
    {"id": "public_output_scope_confirmation_required_example", "path": "examples/public-scope-confirmation-required-output.json"},
    {"id": "public_output_blocked_example", "path": "examples/public-blocked-output.json"}
  ],
  "schemas": [
    {"id": "review_gate_schema", "path": "schemas/review-gate.schema.json"},
    {"id": "public_input_branch_review", "path": "schemas/public-branch-review-input.schema.json"},
    {"id": "public_input_aggregate", "path": "schemas/public-input.schema.json"},
    {"id": "public_invocation_error", "path": "schemas/public-invocation-error.schema.json"},
    {"id": "public_output_passed", "path": "schemas/public-passed-output.schema.json"},
    {"id": "public_output_implementation_required", "path": "schemas/public-implementation-required-output.schema.json"},
    {"id": "public_output_scope_confirmation_required", "path": "schemas/public-scope-confirmation-required-output.schema.json"},
    {"id": "public_output_blocked", "path": "schemas/public-blocked-output.schema.json"}
  ],
  "validators": [
    {"id": "review_gate_recorder", "command": "scripts/review-branch.sh", "runtime_command": "review-branch", "objective_scope": "Record an already completed AI review while rebuilding objective task, range, HEAD, report, assignment, artifact and freshness facts"},
    {"id": "review_gate_checker", "command": "scripts/check-review-gate.sh", "runtime_command": "check-review-gate", "objective_scope": "Validate current review artifact schema, complete range, raw report retention, finding lifecycle, final reviewer freshness and exact typed exit"},
    {"id": "public_invocation", "command": "scripts/invoke.sh", "runtime_command": "invoke-stage0-skill", "objective_scope": "Validate the public input, rerun the owner checker, derive actual exit and serialize one declared minimal DTO"}
  ],
  "external_exits": [
    {"id": "passed", "evidence": "all qualified findings closed and a fresh final reviewer passed the complete current range", "consumer": {"kind": "skill", "id": "guru-review-task-publication"}},
    {"id": "implementation_required", "evidence": "one or more qualified current-scope findings remain open", "consumer": {"kind": "workflow", "id": "guru-branch-review-implementation-router"}},
    {"id": "scope_confirmation_required", "evidence": "one or more unconfirmed nonstandard proposals require dedicated clarification", "consumer": {"kind": "workflow", "id": "guru-branch-review-scope-router"}},
    {"id": "blocked", "evidence": "required evidence, lifecycle, dependency or objective freshness is unavailable", "consumer": {"kind": "stop", "id": "branch-review-blocked"}}
  ],
  "reentry": {
    "identity": "mode, task, base, committed HEAD, review intent, planning, Phase 2, ledger, Docs SSOT, assignment, reports, findings, range, Gate and actual exit",
    "freshness": "every implementation, scope decision, commit, report, assignment or HEAD change reruns all 13 preconditions and the complete review lifecycle",
    "stale_behavior": "fail_closed"
  },
  "tests": ["tests/test_contract.py"],
  "platform_destinations": ["shared", "codex", "cursor", "claude"],
  "public_contracts": {
    "input": {
      "kind": "structured_json",
      "aggregate_schema": {"schema_id": "guru-production-review-branch-input-aggregate-1.0", "path": "schemas/public-input.schema.json"},
      "profiles": [
        {
          "id": "branch_review",
          "schema": {"schema_id": "guru-production-review-branch-input-branch-review-1.0", "path": "schemas/public-branch-review-input.schema.json"},
          "example": {"id": "branch_review_input", "path": "examples/public-branch-review-input.json"},
          "discriminator": {"field": "profile", "value": "branch_review"}
        }
      ]
    },
    "invocation": {
      "command_id": "run-skill-command",
      "wrapper": "scripts/invoke.sh",
      "input_binding": {"kind": "structured_json", "profile_id": "branch_review"},
      "stdout_contract": "single_typed_exit",
      "error_schema": {"schema_id": "guru-production-review-branch-invocation-error-1.0", "path": "schemas/public-invocation-error.schema.json"},
      "error_example": {"id": "invalid_public_input", "path": "examples/public-invocation-error.json"},
      "example_argv": ["--input", "examples/public-branch-review-input.json", "--owner-result", "examples/review-gate.json"]
    },
    "outputs": [
      {"exit_id": "passed", "schema": {"schema_id": "guru-production-review-branch-output-passed-1.0", "path": "schemas/public-passed-output.schema.json"}, "example": {"id": "passed_output", "path": "examples/public-passed-output.json"}, "consumer_use_ids": ["project_passed"]},
      {"exit_id": "implementation_required", "schema": {"schema_id": "guru-production-review-branch-output-implementation-required-1.0", "path": "schemas/public-implementation-required-output.schema.json"}, "example": {"id": "implementation_required_output", "path": "examples/public-implementation-required-output.json"}, "consumer_use_ids": ["project_implementation_required"]},
      {"exit_id": "scope_confirmation_required", "schema": {"schema_id": "guru-production-review-branch-output-scope-confirmation-required-1.0", "path": "schemas/public-scope-confirmation-required-output.schema.json"}, "example": {"id": "scope_confirmation_required_output", "path": "examples/public-scope-confirmation-required-output.json"}, "consumer_use_ids": ["project_scope_confirmation_required"]},
      {"exit_id": "blocked", "schema": {"schema_id": "guru-production-review-branch-output-blocked-1.0", "path": "schemas/public-blocked-output.schema.json"}, "example": {"id": "blocked_output", "path": "examples/public-blocked-output.json"}, "consumer_use_ids": ["project_blocked"]}
    ],
    "consumer_inputs": [
      {
        "id": "publication_seed_input",
        "consumer": {"kind": "skill", "id": "guru-review-task-publication"},
        "payload_kind": "structured_json",
        "contract": {"kind": "planned_skill_input_seed", "seed_fields": ["task_ref", "reviewed_head", "review_ref"]}
      },
      {
        "id": "implementation_required_workflow_input",
        "consumer": {"kind": "workflow", "id": "guru-branch-review-implementation-router"},
        "payload_kind": "structured_json",
        "contract": {"kind": "json_schema", "schema_id": "guru-production-review-branch-workflow-implementation-required-input-1.0", "path": "consumers/workflow/production/review-branch-implementation-required.schema.json"}
      },
      {
        "id": "scope_confirmation_workflow_input",
        "consumer": {"kind": "workflow", "id": "guru-branch-review-scope-router"},
        "payload_kind": "structured_json",
        "contract": {"kind": "json_schema", "schema_id": "guru-production-review-branch-workflow-scope-confirmation-input-1.0", "path": "consumers/workflow/production/review-branch-scope-confirmation.schema.json"}
      },
      {
        "id": "blocked_stop_input",
        "consumer": {"kind": "stop", "id": "branch-review-blocked"},
        "payload_kind": "zero_payload"
      }
    ],
    "projections": [
      {
        "id": "project_passed",
        "exit_id": "passed",
        "consumer_input_id": "publication_seed_input",
        "operation": "select",
        "mappings": [
          {"source": "task_ref", "target": "task_ref"},
          {"source": "reviewed_head", "target": "reviewed_head"},
          {"source": "review_ref", "target": "review_ref"}
        ]
      },
      {"id": "project_implementation_required", "exit_id": "implementation_required", "consumer_input_id": "implementation_required_workflow_input", "operation": "direct"},
      {"id": "project_scope_confirmation_required", "exit_id": "scope_confirmation_required", "consumer_input_id": "scope_confirmation_workflow_input", "operation": "direct"},
      {"id": "project_blocked", "exit_id": "blocked", "consumer_input_id": "blocked_stop_input", "operation": "select", "mappings": []}
    ],
    "private_artifacts": [
      {
        "id": "review_gate",
        "kind": "gate_evidence",
        "schema": {"schema_id": "https://github.com/castbox/guru-trellis/schemas/guru-review-gate-2.0.json", "path": "schemas/review-gate.schema.json"},
        "persistence": "task_local_tracked"
      }
    ]
  }
}
